@page
@model RequestAccessModel
@{
    ViewData["Title"] = "Request Access";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" dir="ltr" data-theme-mode="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Unified</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    <link href="~/assets/libs/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/assets/css/styles.css" rel="stylesheet">
    <link href="~/assets/CSS/icons.css" rel="stylesheet">
</head>
<body class="authentication-background">
<div class="container-xxl">
    <div class="authentication-wrapper authentication-cover authentication-bg">
        <div class="authentication-inner row m-0">
            <div class="d-none d-lg-flex col-lg-7 authentication-bg p-0">
                <div class="authentication-cover-content">
                    <div class="p-5 text-white">
                        <h1 class="display-5 fw-bold mb-3">Unified</h1>
                        <p class="lead opacity-75">Choose the access path that matches your role.</p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-5 d-flex align-items-center authentication-bg py-sm-5 p-4">
                <div class="w-100" style="max-width: 440px; margin: auto;">
                    <div class="mb-4 text-center text-white">
                        <h4 class="fw-semibold mb-1 text-white">Request Access</h4>
                        <p class="mb-0 text-white-50">Select the path for your account type.</p>
                    </div>

                    <div class="d-grid gap-3">
                        <a asp-page="./RegisterAccountManager" class="btn btn-primary btn-lg py-3">
                            <i class="ri-shield-user-line me-2"></i> Account Manager
                        </a>
                        <a asp-page="./Register" class="btn btn-outline-light btn-lg py-3 text-white">
                            <i class="ri-user-add-line me-2"></i> Other
                        </a>
                    </div>

                    <p class="text-center mt-4 mb-0 text-white-50 small">
                        Already have an account? <a asp-page="./Login" class="text-white fw-semibold">Sign in</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/assets/libs/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
