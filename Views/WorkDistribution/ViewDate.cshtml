@using Unified.Models.WorkDistribution
@{
    ViewData["Title"] = "Work Distribution";
    var entry = (WorkDistribution)ViewBag.Entry;
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">
            <i class="bx bx-list-ul me-2"></i>@entry.Date.ToString("dddd, dd MMM yyyy")
        </h4>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bx bx-arrow-back me-1"></i>Back</a>
    </div>

    <div class="card">
        <div class="card-body">
            <pre class="work-dist-body" data-wd-body="1">@entry.Body</pre>
            <hr />
            <small class="text-muted">
                Posted by @(entry.CreatedBy?.DisplayName ?? "Unknown") ·
                Last updated @entry.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
            </small>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/work-distribution-view.js"></script>
}
