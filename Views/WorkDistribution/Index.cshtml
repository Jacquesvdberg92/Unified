@using Unified.Models.WorkDistribution
@{
    ViewData["Title"] = "Work Distribution";
    var today   = (DateTime)ViewBag.Today;
    var todays  = ViewBag.TodaysEntry as WorkDistribution;
    var recent  = (List<WorkDistribution>)ViewBag.Recent;
    var canEdit = User.IsInRole(Unified.Models.Identity.Roles.BrandManager) || User.IsInRole(Unified.Models.Identity.Roles.TeamLeader);
}

<div class="container-xxl flex-grow-1 container-p-y">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0"><i class="bx bx-list-ul me-2"></i>Work Distribution</h4>
        @if (canEdit)
        {
            <a asp-action="Edit" class="btn btn-primary"><i class="bx bx-plus me-1"></i>Post Today's Distribution</a>
        }
    </div>

    @* Today's card *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bx bx-calendar-check me-2"></i>Today — @today.ToString("dddd, dd MMM yyyy")</h5>
            @if (canEdit && todays != null)
            {
                <a asp-action="Edit" asp-route-date="@today.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-secondary">
                    <i class="bx bx-edit me-1"></i>Edit
                </a>
            }
        </div>
        <div class="card-body">
            @if (todays != null)
            {
                <pre class="work-dist-body mb-0">@todays.Body</pre>
                <small class="text-muted">Posted by @(todays.CreatedBy?.DisplayName ?? "Unknown") · @todays.UpdatedAt.ToLocalTime().ToString("HH:mm")</small>
            }
            else
            {
                <p class="text-muted mb-0">No distribution posted yet for today.
                    @if (canEdit)
                    {
                        <a asp-action="Edit">Post one now.</a>
                    }
                </p>
            }
        </div>
    </div>

    @* Recent history *@
    @if (recent.Any(r => r.Date != today.Date))
    {
        <h6 class="text-muted mb-3">Recent Distributions</h6>
        <div class="row g-3">
            @foreach (var entry in recent.Where(r => r.Date != today.Date))
            {
                <div class="col-12">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                            <span class="fw-semibold">@entry.Date.ToString("dddd, dd MMM yyyy")</span>
                            <div class="d-flex gap-2">
                                <a asp-action="ViewDate" asp-route-date="@entry.Date.ToString("yyyy-MM-dd")"
                                   class="btn btn-sm btn-outline-primary">View</a>
                                @if (canEdit)
                                {
                                    <a asp-action="Edit" asp-route-date="@entry.Date.ToString("yyyy-MM-dd")"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <form asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this entry?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@entry.Id" />
                                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                }
                            </div>
                        </div>
                        <div class="card-body py-2">
                            <pre class="work-dist-body mb-0 small text-truncate-3">@entry.Body</pre>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    pre.work-dist-body {
        white-space: pre-wrap;
        word-break: break-word;
        font-family: inherit;
        font-size: 0.9rem;
        background: transparent;
        border: none;
        padding: 0;
        margin: 0;
    }
    .text-truncate-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
