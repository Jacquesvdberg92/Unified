@model Unified.Models.EmailTemplates.EmailTemplate
@{
    ViewData["Title"] = "Preview - " + Model.Title;
    var brands          = (List<Unified.Models.EmailTemplates.Brand>)ViewBag.Brands;
    var renderedHtml    = (string)ViewBag.RenderedHtml;
    var renderedSubject = (string)ViewBag.RenderedSubject;
    var selectedBrandId = (int?)ViewBag.SelectedBrandId;
    var canEdit  = User.IsInRole("BrandManager") || User.IsInRole("TeamLeader") || User.IsInRole("SwissArmyKnife");
    var hasBrand = selectedBrandId.HasValue;
}

<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    <div>
        <h1 class="page-title fw-semibold fs-18 mb-0">@Model.Title</h1>
        @if (Model.Brand != null)
        {
            <small class="text-muted">Default brand: <span class="fw-semibold">@Model.Brand.Name</span></small>
        }
        else
        {
            <small class="text-muted fst-italic">Master template - select a brand below to resolve links</small>
        }
    </div>
    <div class="d-flex gap-2 mt-2 mt-md-0">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="ri-arrow-left-line me-1"></i>Back
        </a>
        @if (canEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                <i class="ri-edit-line me-1"></i>Edit Template
            </a>
        }
    </div>
</div>

@* Brand selector *@
<div class="card mb-3 border-primary">
    <div class="card-body py-2">
        <form method="get" class="d-flex align-items-center gap-3 flex-wrap">
            <input type="hidden" name="id" value="@Model.Id" />
            <i class="ri-building-4-line text-primary fs-5"></i>
            <label class="mb-0 fw-semibold text-muted">Select Brand:</label>
            <select name="brandId" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                <option value="">-- No brand (raw tokens) --</option>
                @foreach (var b in brands)
                {
                    <option value="@b.Id" selected="@(selectedBrandId == b.Id ? "selected" : null)">@b.Name</option>
                }
            </select>
            @if (!hasBrand)
            {
                <small class="text-warning"><i class="ri-error-warning-line me-1"></i>Select a brand to resolve dynamic links before copying.</small>
            }
        </form>
    </div>
</div>

@* Copy actions *@
<div class="card mb-3 @(hasBrand ? "border-success" : "border-secondary")">
    <div class="card-header py-2 d-flex align-items-center gap-2">
        <i class="ri-clipboard-line text-success fs-5"></i>
        <span class="fw-semibold">Copy for ZoHo / Email</span>
        @if (hasBrand)
        {
            <span class="badge bg-success ms-1">@(brands.FirstOrDefault(b => b.Id == selectedBrandId)?.Name ?? "")</span>
        }
    </div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            Select a brand above, then copy either the <strong>HTML body</strong>
            (paste into ZoHo HTML editor) or the <strong>Subject line</strong> separately.
        </p>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <button id="copyBodyBtn" class="btn btn-success" @(!hasBrand ? "disabled" : "")>
                <i class="ri-file-copy-line me-1"></i>Copy Email Body (HTML)
            </button>
            <button id="copyPlainBtn" class="btn btn-outline-secondary" @(!hasBrand ? "disabled" : "")>
                <i class="ri-clipboard-line me-1"></i>Copy as Rich Text (preserves links)
            </button>
            <button id="copySubjectBtn" class="btn btn-outline-success" @(!hasBrand ? "disabled" : "")>
                <i class="ri-text me-1"></i>Copy Subject Line
            </button>
            @if (hasBrand)
            {
                <small class="text-muted ms-2">Subject: <em>@renderedSubject</em></small>
            }
        </div>
    </div>
</div>

@* Preview panel *@
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div><strong>Subject:</strong> <span class="ms-1">@renderedSubject</span></div>
        @if (!hasBrand)
        {
            <span class="badge bg-warning text-dark">Raw tokens - select a brand to resolve links</span>
        }
    </div>
    <div class="card-body p-0">
        <iframe id="previewFrame" style="width:100%;min-height:520px;border:0;" srcdoc=""></iframe>
    </div>
</div>

@section Scripts {
<div id="previewData"
     data-html="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(renderedHtml))"
     data-subject="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(renderedSubject))"
     hidden></div>
<script src="@Url.Content("~/js/email-templates.js")"></script>
}
