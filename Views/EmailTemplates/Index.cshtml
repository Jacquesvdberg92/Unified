@model IEnumerable<Unified.Models.EmailTemplates.EmailTemplate>
@{
    ViewData["Title"] = "Email Templates";
    var brands = (List<Unified.Models.EmailTemplates.Brand>)ViewBag.Brands;
    var selectedBrandId = (int?)ViewBag.SelectedBrandId;
    var canEdit = User.IsInRole("BrandManager") || User.IsInRole("TeamLeader") || User.IsInRole("SwissArmyKnife");
}

<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    <h1 class="page-title fw-semibold fs-18 mb-0">Email Templates</h1>
    <div class="d-flex gap-2">
        @if (User.IsInRole("BrandManager"))
        {
            <a asp-action="BrandManager" class="btn btn-outline-secondary btn-sm">
                <i class="ri-building-line me-1"></i> Brands
            </a>
        }
        @if (canEdit)
        {
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="ri-add-line me-1"></i> New Template
            </a>
        }
    </div>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex align-items-center gap-3 flex-wrap">
            <label class="mb-0 fw-semibold">Filter by Brand:</label>
            <select name="brandId" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                <option value="">All</option>
                @foreach (var b in brands)
                {
                    <option value="@b.Id" selected="@(selectedBrandId == b.Id ? "selected" : null)">@b.Name</option>
                }
            </select>
            @if (selectedBrandId.HasValue)
            {
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Clear</a>
            }
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table id="templatesTable" class="table table-hover nowrap w-100">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Subject</th>
                    <th>Brand</th>
                    <th>Updated</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td>@t.Title</td>
                        <td class="text-muted small">@t.SubjectLine</td>
                        <td>
                            @if (t.Brand != null)
                            {
                                <span class="badge bg-primary">@t.Brand.Name</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Master</span>
                            }
                        </td>
                        <td>@t.UpdatedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-nowrap">
                            <a asp-action="Preview" asp-route-id="@t.Id"
                               asp-route-brandId="@(t.BrandId)"
                               class="btn btn-sm btn-outline-info">
                                <i class="ri-eye-line me-1"></i>Preview &amp; Copy
                            </a>
                            @if (canEdit)
                            {
                                <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary ms-1">
                                    <i class="ri-edit-line me-1"></i>Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@t.Id" method="post" class="d-inline ms-1"
                                      onsubmit="return confirm('Delete this template?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="@Url.Content("~/assets/libs/datatables.net-bs5/js/dataTables.bootstrap5.min.js")"></script>
    <script src="@Url.Content("~/js/email-templates.js")"></script>
}
