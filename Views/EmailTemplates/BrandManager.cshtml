@model IEnumerable<Unified.Models.EmailTemplates.Brand>
@{
    ViewData["Title"] = "Brand Manager";
}

<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    <h1 class="page-title fw-semibold fs-18 mb-0">Brand Manager</h1>
    <a asp-action="CreateBrand" class="btn btn-primary btn-sm">
        <i class="ri-add-line me-1"></i> New Brand
    </a>
</div>

@foreach (var brand in Model)
{
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@brand.Name</h5>
            <div class="d-flex gap-2">
                <a asp-action="EditBrand" asp-route-id="@brand.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <form asp-action="DeleteBrand" asp-route-id="@brand.Id" method="post" class="d-inline"
                      onsubmit="return confirm('Delete brand @brand.Name?')">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3"><strong>CRM:</strong> @(brand.CrmUrl ?? "—")</div>
                <div class="col-md-3"><strong>Quemetrics:</strong> @(brand.QuemetricsUrl ?? "—")</div>
                <div class="col-md-6">
                    <strong>Brand Links:</strong>
                    @{
                        var links = brand.GetBrandLinks();
                    }
                    @if (links.Any())
                    {
                        <ul class="mb-0 ps-3">
                            @foreach (var l in links)
                            {
                                <li>@l.Label — <a href="@l.Url" target="_blank">@l.Url</a></li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span class="text-muted">None configured</span>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(brand.FooterSignatureHtml) || !string.IsNullOrWhiteSpace(brand.ZohoSignatureNote))
            {
                <hr />
                <h6>ZoHo Signature</h6>
                @if (!string.IsNullOrWhiteSpace(brand.ZohoSignatureNote))
                {
                    <p class="text-muted small">@brand.ZohoSignatureNote</p>
                }
                @if (!string.IsNullOrWhiteSpace(brand.FooterSignatureHtml))
                {
                    <div class="border rounded p-2 bg-light mb-2" id="sig-preview-@brand.Id">
                        @Html.Raw(brand.FooterSignatureHtml)
                    </div>
                    <button class="btn btn-sm btn-outline-secondary copy-sig-btn"
                            data-brand-id="@brand.Id"
                            data-sig="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(brand.FooterSignatureHtml))">
                        <i class="ri-clipboard-line me-1"></i> Copy Signature HTML
                    </button>
                }
            }
        </div>
    </div>
}

@section Scripts {
<script src="@Url.Content("~/js/email-templates.js")"></script>
}, 2500);
                });
            });
        });
    </script>
}
