@using Unified.Models.Dashboard
@{
    ViewData["Title"] = "Dashboard";
    var widgets = (List<DashboardWidget>)ViewBag.Widgets;
}

<!-- Start::app-content -->
<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    <h1 class="page-title fw-semibold fs-18 mb-0">Dashboard</h1>
    <div class="ms-md-1 ms-0 d-flex align-items-center gap-2">
        <nav>
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="javascript:void(0);">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
            </ol>
        </nav>
        <a asp-controller="Home" asp-action="Customize" class="btn btn-sm btn-primary ms-3">
            <i class="bx bx-slider me-1"></i> Customize
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3">
    @foreach (var w in widgets)
    {
        <div class="col-12 col-md-@w.ColSpan" data-widget-key="@w.WidgetKey">
            @switch (w.WidgetKey)
            {
                case "updates_feed":
                    await Html.RenderPartialAsync("~/Views/Home/Widgets/_UpdatesFeed.cshtml");
                    break;
                case "work_distribution":
                    await Html.RenderPartialAsync("~/Views/Home/Widgets/_WorkDistribution.cshtml");
                    break;
                case "poi_simulations":
                    await Html.RenderPartialAsync("~/Views/Home/Widgets/_PoiSimulations.cshtml");
                    break;
                case "poi_report":
                    await Html.RenderPartialAsync("~/Views/Home/Widgets/_PoiReport.cshtml");
                    break;
                case "my_schedule":
                    await Html.RenderPartialAsync("~/Views/Home/Widgets/_MySchedule.cshtml");
                    break;
                case "performance":
                    await Html.RenderPartialAsync("~/Views/Home/Widgets/_Performance.cshtml");
                    break;
                case "attendance":
                    await Html.RenderPartialAsync("~/Views/Home/Widgets/_Attendance.cshtml");
                    break;
                case "reports":
                    await Html.RenderPartialAsync("~/Views/Home/Widgets/_Reports.cshtml");
                    break;
                case "cs_live_help":
                    await Html.RenderPartialAsync("~/Views/Home/Widgets/_CsLiveHelp.cshtml");
                    break;
                case "quick_links":
                    await Html.RenderPartialAsync("~/Views/Home/Widgets/_QuickLinks.cshtml");
                    break;
            }
        </div>
    }

    @if (!widgets.Any())
    {
        <div class="col-12">
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="bx bx-layout fs-1 text-muted mb-2"></i>
                    <h5>Your dashboard is empty</h5>
                    <p class="text-muted">Add widgets to personalise your view.</p>
                    <a asp-controller="Home" asp-action="Customize" class="btn btn-primary">
                        <i class="bx bx-plus me-1"></i> Add Widgets
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@* ── POI Log Modal ─────────────────────────────────────────────────────── *@
<div class="modal fade" id="poiLogModal" tabindex="-1" aria-labelledby="poiLogModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="poiLogModalLabel">
                    <i class="bx bx-id-card me-2 text-primary"></i>Log POI Simulation
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="poiLogModalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>
