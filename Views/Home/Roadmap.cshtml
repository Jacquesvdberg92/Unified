<script>
document.addEventListener('DOMContentLoaded', function() {
    const toggleBtn = document.getElementById('viewToggleBtn');
    const toggleLabel = document.getElementById('viewToggleLabel');
    const technicalView = document.getElementById('technicalView');
    const humanFriendlyView = document.getElementById('humanFriendlyView');

    // Get initial view preference from localStorage or default to human friendly
    let isHumanFriendlyMode = localStorage.getItem('roadmapView') !== 'technical';

    // Apply initial state
    updateViewMode(isHumanFriendlyMode);

    // Toggle button click handler
    toggleBtn.addEventListener('click', function() {
        isHumanFriendlyMode = !isHumanFriendlyMode;
        localStorage.setItem('roadmapView', isHumanFriendlyMode ? 'humanFriendly' : 'technical');
        updateViewMode(isHumanFriendlyMode);
    });

    function updateViewMode(isHriendly) {
        if (isHriendly) {
            // Show Human Friendly, hide Technical
            humanFriendlyView.style.display = 'block';
            technicalView.style.display = 'none';
            toggleLabel.textContent = 'Technical Details';
            toggleBtn.classList.remove('btn-outline-primary');
            toggleBtn.classList.add('btn-outline-secondary');
        } else {
            // Show Technical, hide Human Friendly
            technicalView.style.display = 'block';
            humanFriendlyView.style.display = 'none';
            toggleLabel.textContent = 'Human Friendly';
            toggleBtn.classList.remove('btn-outline-secondary');
            toggleBtn.classList.add('btn-outline-primary');
        }
    }
});
</script>

