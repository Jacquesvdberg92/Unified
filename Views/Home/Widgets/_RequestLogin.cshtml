@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="card h-100">
    <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-4">
        <i class="bx bx-desktop text-primary mb-2" style="font-size: 2.5rem;"></i>
        <h6 class="card-title fw-semibold mb-1">Request Google Login</h6>
        <p class="text-muted small mb-3">Sends your name and AnyDesk ID to the IT Telegram channel so they can log you in remotely.</p>

        <button id="requestLoginBtn" class="btn btn-primary px-4" data-token="@token">
            <i class="bx bx-send me-1"></i> Request Login
        </button>

        <div id="requestLoginMsg" class="mt-3 small" style="display:none;"></div>
    </div>
</div>

<script>
(function () {
    var btn = document.getElementById('requestLoginBtn');
    var msg = document.getElementById('requestLoginMsg');
    btn.addEventListener('click', function () { sendLoginRequest(btn.getAttribute('data-token')); });

function sendLoginRequest(token) {

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Sending…';
    msg.style.display = 'none';

    fetch('/Home/RequestLogin', {
        method: 'POST',
        headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/json' },
        credentials: 'same-origin'
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        msg.style.display = 'block';
        if (data.success) {
            msg.className = 'mt-3 small text-success';
            msg.innerHTML = '<i class="bx bx-check-circle me-1"></i> Request sent! IT will log you in shortly.';
            btn.innerHTML = '<i class="bx bx-check me-1"></i> Sent';
            btn.classList.replace('btn-primary', 'btn-success');
            // Re-enable after 5 minutes
            setTimeout(function() {
                btn.disabled = false;
                btn.innerHTML = '<i class="bx bx-send me-1"></i> Request Login';
                btn.classList.replace('btn-success', 'btn-primary');
                msg.style.display = 'none';
            }, 300000);
        } else {
            msg.className = 'mt-3 small text-danger';
            msg.innerHTML = '<i class="bx bx-error-circle me-1"></i> ' + (data.error || 'Something went wrong.');
            btn.disabled = false;
            btn.innerHTML = '<i class="bx bx-send me-1"></i> Request Login';
        }
    })
    .catch(function() {
        msg.style.display = 'block';
        msg.className = 'mt-3 small text-danger';
        msg.innerHTML = '<i class="bx bx-error-circle me-1"></i> Network error. Please try again.';
        btn.disabled = false;
        btn.innerHTML = '<i class="bx bx-send me-1"></i> Request Login';
    });
}
}());
</script>
