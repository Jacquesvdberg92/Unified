@using Unified.Services
@using Unified.Models.Poi
@inject PoiSimulationService PoiService

@{
    var recent = await PoiService.GetFilteredAsync(null, DateTime.Today.AddDays(-7), null, null);
    recent = recent.Take(6).ToList();
}

<div class="card h-100">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h6 class="card-title mb-0"><i class="bx bx-id-card me-2 text-primary"></i>POI Simulations</h6>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#poiLogModal"
                    data-modal-src="/PoiSimulation/LogPartial">
                <i class="bx bx-plus me-1"></i> Add
            </button>
            <a asp-controller="PoiSimulation" asp-action="Index" class="btn btn-sm btn-light">View All</a>
        </div>
    </div>
    <div class="card-body p-0">
        @if (!recent.Any())
        {
            <div class="p-3 text-muted text-center">No POI simulations in the last 7 days.</div>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @foreach (var sim in recent)
                {
                    <li class="list-group-item px-3 py-2 d-flex justify-content-between align-items-center">
                        <div>
                            <span class="fw-semibold">@sim.ClientId</span>
                            <span class="text-muted small ms-1">— @(sim.Brand?.Name ?? "—")</span>
                            <div class="text-muted small">@sim.SimulatedAt.ToString("dd MMM HH:mm")</div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge @(sim.Status == PoiStatus.Received ? "bg-success-transparent text-success" : sim.Status == PoiStatus.Restricted ? "bg-danger-transparent text-danger" : "bg-warning-transparent text-warning")">@sim.Status</span>
                            @if (sim.Status == PoiStatus.Pending)
                            {
                                <form asp-controller="PoiSimulation" asp-action="MarkReceived" method="post" class="d-inline"
                                      data-ajax-form data-widget-key="poi_simulations" data-always-reload="true">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@sim.Id" />
                                    <input type="hidden" name="returnUrl" value="/" />
                                    <button type="submit" class="btn btn-xs btn-success py-0 px-2" title="Mark as Received"
                                            style="font-size:0.72rem;">
                                        <i class="bx bx-check"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>
