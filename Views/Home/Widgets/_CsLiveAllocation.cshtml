@using Unified.Services
@inject CsLiveAllocationService CsHelpService

@{
    var slots = await CsHelpService.GetSlotsForDateAsync(DateTime.Today);
    var now   = DateTime.Now.Hour;
    var current = slots.FirstOrDefault(s => s.SlotHour == now);
    var upcoming = slots.Where(s => s.SlotHour > now).Take(3).ToList();
}

<div class="card h-100">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h6 class="card-title mb-0"><i class="bx bx-headphone me-2 text-primary"></i>CS Live Allocation</h6>
        <a asp-controller="CsLiveAllocation" asp-action="Index" class="btn btn-sm btn-light">View</a>
    </div>
    <div class="card-body">
        @if (!slots.Any())
        {
            <div class="text-muted text-center py-3">No CS Live Allocation for today.</div>
        }
        else
        {
            @if (current != null)
            {
                <div class="alert alert-primary py-2 mb-2">
                    <div class="small fw-semibold">Now (@current.SlotHour:00 – @(current.SlotHour + 1):00)</div>
                    <div>@(current.Agent1?.DisplayName ?? "—") &amp; @(current.Agent2?.DisplayName ?? "—")</div>
                </div>
            }
            @if (upcoming.Any())
            {
                <div class="small text-muted fw-semibold mb-1">Upcoming</div>
                <ul class="list-unstyled mb-0">
                    @foreach (var s in upcoming)
                    {
                        <li class="d-flex justify-content-between py-1 border-bottom">
                            <span class="small text-muted">@s.SlotHour:00 – @(s.SlotHour + 1):00</span>
                            <span class="small text-muted">@(s.Agent1?.DisplayName ?? "—") / @(s.Agent2?.DisplayName ?? "—")</span>
                        </li>
                    }
                </ul>
            }
        }
    </div>
</div>
