<div class="card h-100">
    <div class="card-header">
        <h6 class="card-title mb-0"><i class="bx bx-link me-2 text-primary"></i>Quick Links</h6>
    </div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-6">
                <a asp-controller="Updates" asp-action="Feed" class="btn btn-light w-100 text-start">
                    <i class="bx bx-news me-1 text-primary"></i> Updates
                </a>
            </div>
            <div class="col-6">
                <a asp-controller="WorkDistribution" asp-action="Index" class="btn btn-light w-100 text-start">
                    <i class="bx bx-list-ul me-1 text-primary"></i> Work Dist.
                </a>
            </div>
            <div class="col-6">
                <a asp-controller="PoiSimulation" asp-action="Index" class="btn btn-light w-100 text-start">
                    <i class="bx bx-id-card me-1 text-primary"></i> POI Log
                </a>
            </div>
            <div class="col-6">
                <a asp-controller="PoiSimulation" asp-action="Report" class="btn btn-light w-100 text-start">
                    <i class="bx bx-file-find me-1 text-primary"></i> POI Report
                </a>
            </div>
            <div class="col-6">
                <a asp-controller="Schedule" asp-action="AgentView" class="btn btn-light w-100 text-start">
                    <i class="bx bx-calendar-check me-1 text-primary"></i> Schedule
                </a>
            </div>
            <div class="col-6">
                <a asp-controller="Performance" asp-action="MyReviews" class="btn btn-light w-100 text-start">
                    <i class="bx bx-bar-chart-alt-2 me-1 text-primary"></i> Reviews
                </a>
            </div>
            <div class="col-6">
                <a asp-controller="Vault" asp-action="MyVault" class="btn btn-light w-100 text-start">
                    <i class="bx bx-lock me-1 text-primary"></i> Vault
                </a>
            </div>
            <div class="col-6">
                <a asp-controller="Reports" asp-action="Dashboard" class="btn btn-light w-100 text-start">
                    <i class="bx bx-line-chart me-1 text-primary"></i> Reports
                </a>
            </div>
        </div>
    </div>
</div>
