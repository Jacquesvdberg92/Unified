@using Unified.Models.Sip
@model Unified.Controllers.SipCreateInputModel
@{
    var isEdit = (ViewBag.SipId as int?) is int sipId;
    ViewData["Title"] = isEdit ? "Edit SIP" : "Submit SIP";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">SIP</a></li>
            <li class="breadcrumb-item active">@(isEdit ? "Edit" : "Create")</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header"><h5 class="mb-0">@(isEdit ? "Edit SIP" : "Submit a New SIP")</h5></div>
        <div class="card-body">
            <form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? ViewBag.SipId : null)" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="alert alert-warning">
                    <div class="fw-semibold mb-1">Before you submit</div>
                    <ul class="mb-0 ps-3">
                        <li>Describe the issue/proposal clearly and in detail.</li>
                        <li>For bugs, include exact reproduction steps and whether you could reproduce it.</li>
                        <li>Add logs and screenshots where available.</li>
                        <li>SIPs are proposals; review and prioritization does not guarantee resolution.</li>
                    </ul>
                </div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" maxlength="120" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Category" class="form-label"></label>
                    <select asp-for="Category" class="form-select" asp-items="Html.GetEnumSelectList<SipCategory>()"></select>
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="8" maxlength="2000"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Screenshot (optional)</label>
                    <input type="file" name="screenshot" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp,image/*" />
                    <div class="form-text">Allowed: jpg, jpeg, png, gif, webp. Max size: 5 MB.</div>
                    <span class="text-danger" data-valmsg-for="screenshot" data-valmsg-replace="true"></span>
                    @if (!string.IsNullOrWhiteSpace(ViewBag.ExistingScreenshotPath as string))
                    {
                        <div class="mt-2">
                            <a href="@ViewBag.ExistingScreenshotPath" target="_blank" rel="noopener">Current screenshot</a>
                        </div>
                    }
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">@(isEdit ? "Save Changes" : "Submit SIP")</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
