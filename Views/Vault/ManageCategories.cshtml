@using Unified.Models.Vault
@model List<VaultCategory>

@{
    ViewData["Title"] = "Manage Vault Categories";
}

<div class="container-fluid px-4 py-3" style="max-width:700px">
    <h4 class="fw-bold mb-3">🗂 Manage Vault Categories</h4>

    <div class="table-responsive mb-4">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Icon</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td><i class="@cat.IconCssClass fs-5"></i></td>
                        <td>@cat.Name</td>
                        <td>
                            <span class="badge @(cat.IsCustom ? "bg-warning text-dark" : "bg-secondary")">
                                @(cat.IsCustom ? "Custom" : "System")
                            </span>
                        </td>
                        <td class="text-end">
                            @if (cat.IsCustom)
                            {
                                <form asp-action="DeleteCategory" asp-route-id="@cat.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this category?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-semibold">Add System Category</div>
        <div class="card-body">
            <form asp-action="CreateCategory" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-md-5">
                    <input type="text" name="name" class="form-control"
                           placeholder="Category name" required />
                </div>
                <div class="col-md-4">
                    <input type="text" name="icon" class="form-control"
                           placeholder="Icon CSS class e.g. bx bx-lock" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">Add</button>
                </div>
            </form>
        </div>
    </div>
</div>
