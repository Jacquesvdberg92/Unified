@{
    ViewData["Title"] = "Bulk Provision Credentials";
    var categories = (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Categories;
    var agents     = (List<(string Id, string Name)>)ViewBag.Agents;
}

<div class="container-fluid px-4 py-3" style="max-width:860px">
    <h4 class="fw-bold mb-3">⚙ Bulk Provision Credentials</h4>

    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success">@ok</div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="alert alert-danger">@err</div>
    }

    <form method="post">
        @Html.AntiForgeryToken()

        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold">Step 1 — Credential Details</div>
            <div class="card-body row g-3">
                <div class="col-md-4">
                    <label class="form-label">Category</label>
                    <select name="categoryId" asp-items="categories" class="form-select" required></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Label</label>
                    <input type="text" name="label" class="form-control" placeholder="e.g. Colbari CRM" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Username</label>
                    <input type="text" name="username" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <input type="password" id="bulkPwd" name="plainPassword"
                               class="form-control" required />
                        <button type="button" class="btn btn-outline-secondary" id="toggleBulkPwd">👁</button>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">URL</label>
                    <input type="url" name="url" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Notes</label>
                    <input type="text" name="notes" class="form-control" />
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-header d-flex justify-content-between align-items-center fw-semibold">
                Step 2 — Select Target Agents
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="selectAll">All</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="clearAll">None</button>
                </div>
            </div>
            <div class="card-body" style="max-height:300px;overflow-y:auto">
                @foreach (var (id, name) in agents)
                {
                    <div class="form-check">
                        <input class="form-check-input agent-cb" type="checkbox"
                               name="targetUserIds" value="@id" id="agent_@id" />
                        <label class="form-check-label" for="agent_@id">@name</label>
                    </div>
                }
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Provision</button>
    </form>
</div>

@section Scripts {
<script>
    document.getElementById('toggleBulkPwd').addEventListener('click', function () {
        const f = document.getElementById('bulkPwd');
        f.type = f.type === 'password' ? 'text' : 'password';
        this.textContent = f.type === 'password' ? '👁' : '🙈';
    });
    document.getElementById('selectAll').addEventListener('click', () =>
        document.querySelectorAll('.agent-cb').forEach(c => c.checked = true));
    document.getElementById('clearAll').addEventListener('click', () =>
        document.querySelectorAll('.agent-cb').forEach(c => c.checked = false));
</script>
}
