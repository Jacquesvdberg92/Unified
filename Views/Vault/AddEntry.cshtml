@using Unified.Models.Vault
@model VaultEntry

@{
    ViewData["Title"] = "Add Credential";
    var categories = (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Categories;
}

<div class="container-fluid px-4 py-3" style="max-width:640px">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="fw-bold mb-0">🔑 Add Credential</h4>
        <a asp-action="MyVault" class="btn btn-outline-secondary btn-sm">← Back</a>
    </div>

    <form method="post">
        @Html.AntiForgeryToken()

        <div class="card shadow-sm">
            <div class="card-body row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">Category</label>
                    <select name="CategoryId" asp-items="categories" class="form-select" required></select>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Label</label>
                    <input type="text" name="Label" value="@Model.Label"
                           class="form-control" placeholder="e.g. Colbari CRM" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Username</label>
                    <input type="text" name="Username" value="@Model.Username"
                           class="form-control" autocomplete="username" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Password</label>
                    <div class="input-group">
                        <input type="password" id="plainPassword" name="plainPassword"
                               class="form-control" autocomplete="new-password" required />
                        <button type="button" class="btn btn-outline-secondary" id="togglePwd">👁</button>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">URL</label>
                    <input type="url" name="Url" value="@Model.Url"
                           class="form-control" placeholder="https://..." />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Notes</label>
                    <textarea name="Notes" rows="2" class="form-control">@Model.Notes</textarea>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="MyVault" class="btn btn-link">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    document.getElementById('togglePwd').addEventListener('click', function () {
        const f = document.getElementById('plainPassword');
        f.type = f.type === 'password' ? 'text' : 'password';
        this.textContent = f.type === 'password' ? '👁' : '🙈';
    });
</script>
}
