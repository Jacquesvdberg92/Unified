@using Unified.Models.Performance
@model PerformanceReview

@{
    ViewData["Title"] = "New Performance Review";
    var agents     = (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Agents;
    var categories = (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Categories;
    var preAgentId = (string?)ViewBag.AgentId;
}

<div class="container-fluid px-4 py-3" style="max-width:900px">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="fw-bold mb-0">📝 New Performance Review</h4>
        <a asp-action="TeamReviews" class="btn btn-outline-secondary btn-sm">← Back</a>
    </div>

    <form method="post" id="reviewForm">
        @Html.AntiForgeryToken()

        <div class="card shadow-sm mb-3">
            <div class="card-body row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Agent</label>
                    <select name="AgentId" asp-items="agents" class="form-select" required>
                        <option value="">— Select agent —</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Review Date</label>
                    <input type="date" name="ReviewDate" value="@DateTime.Today.ToString("yyyy-MM-dd")"
                           class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Period</label>
                    <input type="text" name="PeriodLabel" placeholder="e.g. May 2026"
                           class="form-control" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Overall Notes</label>
                    <textarea name="OverallNotes" rows="2" class="form-control"></textarea>
                </div>
            </div>
        </div>

        @* Review items – added dynamically *@
        <h5 class="fw-semibold mb-2">Review Items</h5>
        <div id="itemsContainer"></div>

        <button type="button" class="btn btn-outline-secondary btn-sm mb-3" id="addItemBtn">
            + Add Item
        </button>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@e.ErrorMessage</div>
                }
            </div>
        }

        <div>
            <button type="submit" class="btn btn-primary">Save Review</button>
            <a asp-action="TeamReviews" class="btn btn-link">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    let itemIndex = 0;

    const categoryOptions = @Html.Raw(
        System.Text.Json.JsonSerializer.Serialize(
            Enum.GetValues<ReviewCategory>().Select((c, i) => new { value = i, text = c.ToString() })
        ));

    document.getElementById('addItemBtn').addEventListener('click', addItem);

    function addItem() {
        const container = document.getElementById('itemsContainer');
        const div = document.createElement('div');
        div.className = 'card shadow-sm mb-2 item-card';
        div.innerHTML = `
            <div class="card-body row g-2">
                <div class="col-md-2">
                    <label class="form-label small">Category</label>
                    <select name="category" class="form-select form-select-sm">
                        ${categoryOptions.map(o => `<option value="${o.value}">${o.text}</option>`).join('')}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Reference ID</label>
                    <input type="text" name="refId" class="form-control form-control-sm"
                           placeholder="Ticket / Chat ID" required />
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Rating</label>
                    <input type="number" name="rating" min="1" max="10" value="7"
                           class="form-control form-control-sm" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Positive</label>
                    <input type="text" name="positive" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Improvement</label>
                    <input type="text" name="negative" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Action Note</label>
                    <input type="text" name="actionNote" class="form-control form-control-sm" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <div class="form-check mb-1">
                        <input type="checkbox" name="actionRequired" value="true"
                               class="form-check-input" id="ar_${itemIndex}" />
                        <label class="form-check-label small" for="ar_${itemIndex}">Action?</label>
                    </div>
                </div>
                <div class="col-12 text-end">
                    <button type="button" class="btn btn-outline-danger btn-sm remove-btn">Remove</button>
                </div>
            </div>`;
        div.querySelector('.remove-btn').addEventListener('click', () => div.remove());
        container.appendChild(div);
        itemIndex++;
    }

    @* Auto-add one empty item on load *@
    addItem();
</script>
}
