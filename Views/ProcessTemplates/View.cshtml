@model Unified.Models.ProcessTemplates.ProcessTemplate

@{
    ViewData["Title"] = Model.Title;
    var brands = (IEnumerable<Unified.Models.EmailTemplates.Brand>)ViewBag.Brands;
}

<div class="container-xxl flex-grow-1 container-p-y">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Template Library</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="row g-4">
        @* Template body *@
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0">@Model.Title</h5>
                        <span class="badge bg-label-primary">@Model.Category?.Name</span>
                        @if (!Model.AffectedBrands.Any())
                        {
                            <span class="badge bg-label-secondary ms-1">All Brands</span>
                        }
                        else
                        {
                            @foreach (var pb in Model.AffectedBrands)
                            {
                                <span class="badge bg-label-info ms-1">@pb.Brand?.Name</span>
                            }
                        }
                    </div>
                    <div class="d-flex gap-2">
                        <button id="btnCopy" class="btn btn-primary btn-sm">
                            <i class="bx bx-copy me-1"></i>Copy to Clipboard
                        </button>
                        <a id="btnDownload" href="#" class="btn btn-outline-secondary btn-sm">
                            <i class="bx bx-download me-1"></i>Download .txt
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <pre id="templateBody" class="template-body p-3 rounded bg-light text-muted" style="white-space:pre-wrap;font-family:inherit;"></pre>
                </div>
            </div>
        </div>

        @* Guidance notes *@
        <div class="col-lg-4">
            @if (!string.IsNullOrWhiteSpace(Model.GuidanceNotes))
            {
                <div class="card" id="guidanceCard">
                    <div class="card-header d-flex justify-content-between align-items-center"
                         data-bs-toggle="collapse" data-bs-target="#guidanceBody" style="cursor:pointer;">
                        <h6 class="mb-0"><i class="bx bx-info-circle me-1"></i>Guidance Notes</h6>
                        <i class="bx bx-chevron-up" id="guidanceChevron"></i>
                    </div>
                    <div class="collapse show" id="guidanceBody">
                        <div class="card-body">
                            <div class="ql-snow text-muted"><div class="ql-editor p-0">@Html.Raw(Model.GuidanceNotes)</div></div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script type="application/json" id="templateBodyRaw">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BodyText))</script>
<script>document.getElementById('btnDownload').dataset.filename = '@Html.Raw(Model.Title.Replace(" ", "_"))';</script>
<script src="@Url.Content("~/js/process-templates.js")"></script>
}
