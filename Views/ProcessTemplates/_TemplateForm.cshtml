@model Unified.Models.ProcessTemplates.ProcessTemplate

@{
    bool isSelected(int id) => ((List<int>)ViewBag.SelectedBrandIds).Contains(id);
}

<div class="mb-3">
    <label class="form-label">Title <span class="text-danger">*</span></label>
    <input asp-for="Title" class="form-control" required />
    <span asp-validation-for="Title" class="text-danger small"></span>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label">Category <span class="text-danger">*</span></label>
        <select asp-for="CategoryId" class="form-select" required>
            <option value="">— select —</option>
            @foreach (var cat in (IEnumerable<Unified.Models.ProcessTemplates.TemplateCategory>)ViewBag.Categories)
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger small"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label">Affected Brands</label>
        <select name="brandIds" class="form-select" multiple>
            @foreach (var brand in (IEnumerable<Unified.Models.EmailTemplates.Brand>)ViewBag.Brands)
            {
                <option value="@brand.Id" selected="@(isSelected(brand.Id) ? "selected" : null)">@brand.Name</option>
            }
        </select>
        <div class="form-text">Leave empty = global (all brands).</div>
    </div>
</div>

<div class="mb-3">
    <label class="form-label">Description</label>
    <input asp-for="Description" class="form-control" placeholder="One-liner shown on the library card" />
</div>

<div class="mb-3">
    <label class="form-label">Body Text <span class="text-danger">*</span> <small class="text-muted">(Quill rich text)</small></label>
    <div class="mb-1">
        <button type="button" class="btn btn-sm btn-outline-warning" onclick="insertBlank()">
            Insert [BLANK]
        </button>
    </div>
    <div id="bodyEditor" style="min-height:220px;"></div>
    <input type="hidden" asp-for="BodyText" id="BodyText" />
    <span asp-validation-for="BodyText" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label class="form-label">Guidance Notes <small class="text-muted">(Quill rich text)</small></label>
    <div id="guidanceEditor" style="min-height:120px;"></div>
    <input type="hidden" asp-for="GuidanceNotes" id="GuidanceNotes" />
</div>

<div class="form-check mb-3">
    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
    <label asp-for="IsActive" class="form-check-label">Active</label>
</div>
