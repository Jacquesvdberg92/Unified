@model Unified.Models.ProcessTemplates.ProcessTemplate

@{
    ViewData["Title"] = $"Edit — {Model.Title}";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Template Library</a></li>
            <li class="breadcrumb-item active">Edit</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header"><h5 class="mb-0">Edit Template</h5></div>
                <div class="card-body">
                    <form method="post" asp-action="Edit" asp-route-id="@Model.Id">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedAt" />
                        <input type="hidden" asp-for="CreatedByUserId" />
                        @await Html.PartialAsync("_TemplateForm", Model)
                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a asp-action="View" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-danger">
                <div class="card-header text-danger"><h6 class="mb-0">Danger Zone</h6></div>
                <div class="card-body">
                    <p class="small text-muted">Deactivating hides this template from the library. It can be restored by an administrator.</p>
                    <form method="post" asp-action="Deactivate" asp-route-id="@Model.Id"
                          onsubmit="return confirm('Deactivate this template?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm w-100">
                            <i class="bx bx-hide me-1"></i>Deactivate Template
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="@Url.Content("~/assets/libs/quill/quill.snow.css")" rel="stylesheet" />
    <script src="@Url.Content("~/assets/libs/quill/quill.js")"></script>
    <script src="@Url.Content("~/js/process-templates.js")"></script>
}
