@using Unified.Models.Attendance
@using Unified.Models.Identity
@model List<Unified.Services.AttendanceReportRow>
@{
    ViewData["Title"] = "Attendance Reports";
    string period    = ViewBag.Period;
    DateTime from    = ViewBag.From;
    DateTime to      = ViewBag.To;
    string? agentId  = ViewBag.AgentId;
    var allAgents    = ViewBag.AllAgents as List<AppUser> ?? new();
    string customFrom = ViewBag.CustomFrom ?? from.ToString("yyyy-MM-dd");
    string customTo   = ViewBag.CustomTo   ?? to.ToString("yyyy-MM-dd");

    double  totalHrs = Model.Sum(r => r.BillableHours ?? 0);
}

<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    <h1 class="page-title fw-semibold fs-18 mb-0">
        <i class="bx bx-spreadsheet me-2"></i>Attendance Reports
    </h1>
    <div class="d-flex gap-2 mt-2 mt-md-0">
        <a asp-action="Retrospective" class="btn btn-outline-warning btn-sm">
            <i class="bx bx-time me-1"></i> Pending Approvals
        </a>
        <a asp-action="Holidays" class="btn btn-outline-secondary btn-sm">
            <i class="bx bx-calendar-event me-1"></i> Holidays
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible">@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Filters ─────────────────────────────────────────────────────────────── *@
<form method="get" class="card shadow-sm mb-4">
    <div class="card-body d-flex flex-wrap gap-3 align-items-end">
        <div>
            <label class="form-label fw-semibold mb-1">Period</label>
            <select name="period" id="periodSelect" class="form-select" onchange="toggleCustomDates(this.value)">
                <option value="weekly"   selected="@(period=="weekly"   ? "selected" : null)">Weekly (Mon – today)</option>
                <option value="biweekly" selected="@(period=="biweekly" ? "selected" : null)">Bi-Weekly (14 days)</option>
                <option value="monthly"  selected="@(period=="monthly"  ? "selected" : null)">Monthly (this month)</option>
                <option value="custom"   selected="@(period=="custom"   ? "selected" : null)">Custom range…</option>
            </select>
        </div>
        <div id="customDateRange" style="display:@(period=="custom" ? "flex" : "none"); gap:0.5rem; align-items:flex-end;">
            <div>
                <label class="form-label fw-semibold mb-1">From</label>
                <input type="date" name="customFrom" class="form-control" value="@customFrom" />
            </div>
            <div>
                <label class="form-label fw-semibold mb-1">To</label>
                <input type="date" name="customTo" class="form-control" value="@customTo" />
            </div>
        </div>
        <div>
            <label class="form-label fw-semibold mb-1">Agent</label>
            <select name="agentId" class="form-select">
                <option value="">— All agents —</option>
                @foreach (var a in allAgents)
                {
                    <option value="@a.Id" selected="@(agentId == a.Id ? "selected" : null)">@a.DisplayName</option>
                }
            </select>
        </div>
        <div>
            <button type="submit" class="btn btn-primary">
                <i class="bx bx-filter me-1"></i> Generate
            </button>
        </div>
        <div class="ms-auto text-muted small align-self-center">
            @from.ToString("dd MMM yyyy") – @to.ToString("dd MMM yyyy")
        </div>
    </div>
</form>

@* ── Summary cards ────────────────────────────────────────────────────────── *@
<div class="row g-3 mb-4">
    <div class="col-sm-6">
        <div class="card text-center shadow-sm">
            <div class="card-body py-3">
                <p class="text-muted small mb-1">Total Records</p>
                <h4 class="fw-bold mb-0">@Model.Count</h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card text-center shadow-sm">
            <div class="card-body py-3">
                <p class="text-muted small mb-1">Total Billable Hours</p>
                <h4 class="fw-bold mb-0">@totalHrs.ToString("F1") h</h4>
            </div>
        </div>
    </div>
    </div>

@* ── Report table ─────────────────────────────────────────────────────────── *@
<div class="card shadow-sm">
    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
        <span><i class="bx bx-table me-1"></i> Attendance Detail</span>
        <button class="btn btn-sm btn-outline-secondary" onclick="window.print()">
            <i class="bx bx-printer me-1"></i> Print
        </button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="reportTable">
                <thead class="table">
                    <tr>
                        <th>Agent</th>
                        <th>Date</th>
                        <th>In</th>
                        <th>Out</th>
                        <th>Billable Hrs</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No records for selected period.</td></tr>
                    }
                    @{
                        string? lastAgent = null;
                        double  agentHrs  = 0;
                    }
                    @foreach (var row in Model)
                    {
                        if (lastAgent != null && lastAgent != row.AgentId)
                        {
                            <tr class="table fw-semibold">
                                <td colspan="4" class="text-end text-muted small">Subtotal</td>
                                <td>@agentHrs.ToString("F1") h</td>
                                <td colspan="2"></td>
                            </tr>
                            agentHrs = 0;
                        }
                        agentHrs   += row.BillableHours ?? 0;
                        lastAgent   = row.AgentId;

                        <tr>
                            <td>@row.AgentName</td>
                            <td>@row.WorkDate.ToString("ddd dd MMM")</td>
                            <td>@(row.CheckIn?.ToLocalTime().ToString("HH:mm") ?? "—")</td>
                            <td>@(row.CheckOut?.ToLocalTime().ToString("HH:mm") ?? "—")</td>
                            <td>@(row.BillableHours.HasValue ? $"{row.BillableHours.Value:F1}h" : "—")</td>
                            <td>
                                @{
                                    var typeBadge = row.PayType switch
                                    {
                                        DayPayType.Weekend       => "bg-warning text-dark",
                                        DayPayType.PublicHoliday => "bg-danger",
                                        DayPayType.Vacation      => "bg-info text-dark",
                                        DayPayType.DayOff        => "bg-secondary",
                                        _                        => "bg-primary"
                                    };
                                    var typeLabel = row.PayType switch
                                    {
                                        DayPayType.Weekend => "Weekend Shift",
                                        _                  => row.PayType.ToString()
                                    };
                                }
                                <span class="badge @typeBadge">@typeLabel</span>
                            </td>
                            <td>
                                @{
                                    var statusBadge = row.Status switch
                                    {
                                        AttendanceStatus.Approved      => "bg-success",
                                        AttendanceStatus.Rejected      => "bg-danger",
                                        AttendanceStatus.Retrospective => "bg-warning text-dark",
                                        _                              => "bg-primary"
                                    };
                                }
                                <span class="badge @statusBadge">@row.Status</span>
                            </td>
                            <td>
                                <a asp-controller="AttendanceReport" asp-action="EditLog" asp-route-id="@row.LogId"
                                   class="btn btn-xs btn-outline-secondary py-0 px-1">
                                    <i class="bx bx-edit"></i> Fix
                                </a>
                            </td>
                        </tr>
                    }
                    @if (lastAgent != null)
                    {
                        <tr class="table fw-semibold">
                            <td colspan="4" class="text-end text-muted small">Subtotal</td>
                            <td>@agentHrs.ToString("F1") h</td>
                            <td colspan="3"></td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table">
                    <tr>
                        <td colspan="4" class="fw-bold text-end">TOTAL</td>
                        <td class="fw-bold">@totalHrs.ToString("F1") h</td>
                        <td colspan="3"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script src="@Url.Content("~/js/attendance.js")"></script>
}