@using Unified.Models.Attendance
@model List<AttendanceLog>
@{
    ViewData["Title"] = "Pending Retrospective Approvals";
}

<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    <h1 class="page-title fw-semibold fs-18 mb-0">
        <i class="bx bx-time me-2"></i>Pending Approvals
    </h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-2 mt-md-0">
        <i class="bx bx-arrow-back me-1"></i> Back to Reports
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible">@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible">@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">No pending retrospective entries.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Agent</th>
                            <th>Date</th>
                            <th>Check In</th>
                            <th>Check Out</th>
                            <th>Billable Hrs</th>
                            <th>Agent Note</th>
                            <th style="width:260px">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>@(log.Agent?.DisplayName ?? log.AgentId)</td>
                                <td>@log.WorkDate.ToString("ddd dd MMM yyyy")</td>
                                <td>@(log.CheckInTime?.ToLocalTime().ToString("HH:mm") ?? "—")</td>
                                <td>@(log.CheckOutTime?.ToLocalTime().ToString("HH:mm") ?? "—")</td>
                                <td>@(log.BillableHours.HasValue ? $"{log.BillableHours.Value:F1}h" : "—")</td>
                                <td class="text-muted small">@(log.AgentNote ?? "—")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <form asp-action="Approve" method="post" class="d-flex gap-1 align-items-center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="logId" value="@log.Id" />
                                            <input type="text" name="reviewerNote" class="form-control form-control-sm"
                                                   placeholder="Note (optional)" style="width:110px" />
                                            <button type="submit" class="btn btn-sm btn-success">
                                                <i class="bx bx-check"></i>
                                            </button>
                                        </form>
                                        <form asp-action="Reject" method="post" class="d-flex gap-1 align-items-center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="logId" value="@log.Id" />
                                            <input type="text" name="reviewerNote" class="form-control form-control-sm"
                                                   placeholder="Reason" style="width:110px" />
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="bx bx-x"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
