@using Unified.Models.CsLiveHelp
@model CsRequest
@{
    var statusBadge = Model.Status switch
    {
        CsRequestStatus.Open       => "bg-secondary",
        CsRequestStatus.InProgress => "bg-warning text-dark",
        CsRequestStatus.OnGoing    => "bg-warning text-dark",
        CsRequestStatus.Completed  => "bg-success",
        CsRequestStatus.Escalated  => "bg-danger",
        _                          => "bg-secondary"
    };
    var statusText = Model.Status switch
    {
        CsRequestStatus.Escalated => "Passed to CS",
        _                         => Model.Status.ToString()
    };
    var isTlManager = User.IsInRole("TeamLeader") || User.IsInRole("BrandManager") || User.IsInRole("SwissArmyKnife");
    var assignedName = Model.AssignedTo?.DisplayName ?? Model.AssignedTo?.UserName;
    var teamAllocationName = Model.Comments
        .Where(c => c.IsSystemMessage && c.Body.Contains("Team allocation:"))
        .OrderByDescending(c => c.CreatedAt)
        .Select(c => c.Body.Split("Team allocation:").LastOrDefault()?.Trim().TrimEnd('.'))
        .FirstOrDefault();
    var assignmentLabel = !string.IsNullOrWhiteSpace(teamAllocationName)
        ? $"Team: {teamAllocationName}"
        : assignedName;
}

<div class="card border shadow-sm p-2 small @(Model.Status == CsRequestStatus.Escalated ? "border-danger" : "")" data-card-id="@Model.Id" data-brand-id="@Model.BrandId" data-client-id="@Model.ClientId?.ToLower()">
    <div class="d-flex justify-content-between align-items-start mb-1">
        <span class="badge @statusBadge">@statusText</span>
        <div class="d-flex gap-1 align-items-center">
            @if (Model.IsInternal)
            {
                <span class="badge bg-info text-dark" style="font-size:.65rem">Internal</span>
            }
            <span class="text-muted" style="font-size:.75rem">#@Model.Id</span>
        </div>
    </div>
    <div class="fw-semibold">@(Model.Brand?.Name ?? "—")</div>
    <div class="text-muted">@(Model.RequestType?.Name ?? "—")</div>
    @if (!string.IsNullOrWhiteSpace(Model.CustomDescription))
    {
        <div class="text-muted mt-1" style="font-size:.75rem; white-space:pre-wrap">@Model.CustomDescription</div>
    }
    @if (!string.IsNullOrWhiteSpace(assignmentLabel))
    {
        <div class="text-muted mt-1 cs-assigned-row" style="font-size:.72rem">
            <i class="bx bx-user me-1"></i><span class="cs-assigned-name">@assignmentLabel</span>
        </div>
    }
    else
    {
        <div class="text-muted mt-1 cs-assigned-row" style="font-size:.72rem;display:none">
            <i class="bx bx-user me-1"></i><span class="cs-assigned-name"></span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ClientId))
    {
        <div class="text-muted mt-1 d-flex align-items-center gap-1" style="font-size:.72rem">
            <i class="bx bx-id-card"></i>
            <span class="fw-semibold">@Model.ClientId</span>
            <button type="button"
                    class="btn btn-outline-secondary btn-sm py-0 px-1 copy-client-id-btn"
                    data-client-id="@Model.ClientId"
                    title="Copy Client ID"
                    aria-label="Copy Client ID">
                <i class="bx bx-copy"></i>
            </button>
        </div>
    }
    @{
        var internalCommentCount = Model.Comments.Count(c => c.IsCsInternalOnly);
    }
    @if (internalCommentCount > 0)
    {
        <div class="mt-1">
            <button class="btn btn-link btn-sm p-0 text-muted"
                    style="font-size:.72rem"
                    data-bs-toggle="modal"
                    data-bs-target="#intCommentModal-@Model.Id"
                    title="View thread">
                <i class="bx bx-comment-detail me-1"></i><span class="int-comment-count">@internalCommentCount</span> comment(s) — View thread
            </button>
        </div>
    }
    <div class="text-muted mt-1" style="font-size:.72rem">@Model.CreatedAt.ToString("MMM dd, HH:mm") UTC</div>

    <div class="d-flex gap-1 mt-2 flex-wrap">
        @* Move status *@
        <button class="btn btn-outline-secondary btn-sm py-0 px-2"
                data-bs-toggle="modal"
                data-bs-target="#intStatusModal-@Model.Id"
                title="Move">
            <i class="bx bx-transfer-alt"></i>
        </button>

        @* View Thread / Comment *@
        <button class="btn btn-outline-primary btn-sm py-0 px-2"
                data-bs-toggle="modal"
                data-bs-target="#intCommentModal-@Model.Id"
                title="Thread / Comment">
            <i class="bx bx-comment-add"></i>
        </button>

        @* Resolve Escalation — TL/Manager only, escalated cards *@
        @if (isTlManager && Model.Status == CsRequestStatus.Escalated)
        {
            <button class="btn btn-success btn-sm py-0 px-2"
                    data-bs-toggle="modal"
                    data-bs-target="#intResolveModal-@Model.Id"
                    title="Resolve Escalation">
                <i class="bx bx-check-circle"></i>
            </button>
        }
    </div>
</div>
