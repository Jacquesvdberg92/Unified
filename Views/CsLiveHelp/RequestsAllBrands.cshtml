@using Unified.Models.CsLiveHelp
@using Unified.Models.EmailTemplates
@{
    ViewData["Title"] = "CS Requests – All Brands";
    var requests      = (List<CsRequest>)ViewBag.Requests;
    var types         = (List<CsRequestType>)ViewBag.RequestTypes;
    var brands        = (List<Brand>)ViewBag.Brands;
    var teams         = (List<Unified.Models.Identity.Team>)ViewBag.Teams;
    var isTlManager   = (bool)ViewBag.IsTlManager;

    var openCards       = requests.Where(r => r.Status == CsRequestStatus.Open || r.Status == CsRequestStatus.Escalated).ToList();
    var inProgressCards = requests.Where(r => r.Status == CsRequestStatus.InProgress).ToList();
    var onGoingCards    = requests.Where(r => r.Status == CsRequestStatus.OnGoing).ToList();
    var completedCards  = requests.Where(r => r.Status == CsRequestStatus.Completed).ToList();
}

<div class="container-fluid">

    @if (TempData["Error"] is string err)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bx bx-error-circle me-2"></i>@err
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bx bx-check-circle me-2"></i>@ok
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <h5 class="mb-0"><i class="bx bx-globe me-2"></i>CS Requests – All Brands</h5>
            <span class="badge bg-primary">@requests.Count shown</span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#newInternalRequestModal">
                <i class="bx bx-plus me-1"></i>New Request
            </button>
        </div>
    </div>

    <!-- Kanban board -->
    @Html.AntiForgeryToken()

    <!-- Filter bar -->
    <div class="d-flex flex-wrap gap-2 mb-3 align-items-center" id="allBrandsFilterBar">
        <select id="allBrandsBrandFilter" class="form-select form-select-sm" style="max-width:200px">
            <option value="">All Brands</option>
            @foreach (var b in brands)
            {
                <option value="@b.Id">@b.Name</option>
            }
        </select>
        <input id="allBrandsClientIdFilter" type="search" class="form-control form-control-sm" style="max-width:180px"
               placeholder="Search Client ID…" autocomplete="off" />
        <button type="button" class="btn btn-primary btn-sm" id="allBrandsFilterApply">
            <i class="bx bx-filter-alt me-1"></i>Apply
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="allBrandsFilterClear">
            <i class="bx bx-x me-1"></i>Clear
        </button>
    </div>

    <div class="row g-3">

        @* ── Open ── *@
        <div class="col">
            <div class="card h-100" style="min-width:220px">
                <div class="card-header d-flex align-items-center gap-2 bg-secondary bg-opacity-10">
                    <span class="badge bg-secondary">Open</span>
                    <span class="fw-semibold">Open</span>
                    <span class="badge bg-secondary rounded-pill ms-auto" id="count-Open">@openCards.Count</span>
                </div>
                <div id="col-Open" class="card-body p-2 d-flex flex-column gap-2 kanban-col" data-status="Open" style="min-height:80px">
                    @foreach (var r in openCards) { @await Html.PartialAsync("_InternalBoardCard", r) }
                    @if (!openCards.Any()) { <p class="text-muted small text-center mt-3 empty-col-hint">No open requests</p> }
                </div>
            </div>
        </div>

        @* ── In Progress ── *@
        <div class="col">
            <div class="card h-100" style="min-width:220px">
                <div class="card-header d-flex align-items-center gap-2 bg-warning bg-opacity-10">
                    <span class="badge bg-warning text-dark">InProgress</span>
                    <span class="fw-semibold">In Progress</span>
                    <span class="badge bg-warning text-dark rounded-pill ms-auto" id="count-InProgress">@inProgressCards.Count</span>
                </div>
                <div id="col-InProgress" class="card-body p-2 d-flex flex-column gap-2 kanban-col" data-status="InProgress" style="min-height:80px">
                    @foreach (var r in inProgressCards) { @await Html.PartialAsync("_InternalBoardCard", r) }
                    @if (!inProgressCards.Any()) { <p class="text-muted small text-center mt-3 empty-col-hint">None</p> }
                </div>
            </div>
        </div>

        @* ── On Going ── *@
        <div class="col">
            <div class="card h-100" style="min-width:220px">
                <div class="card-header d-flex align-items-center gap-2 bg-warning bg-opacity-10">
                    <span class="badge bg-warning text-dark">OnGoing</span>
                    <span class="fw-semibold">On Going</span>
                    <span class="badge bg-warning text-dark rounded-pill ms-auto" id="count-OnGoing">@onGoingCards.Count</span>
                </div>
                <div id="col-OnGoing" class="card-body p-2 d-flex flex-column gap-2 kanban-col" data-status="OnGoing" style="min-height:80px">
                    @foreach (var r in onGoingCards) { @await Html.PartialAsync("_InternalBoardCard", r) }
                    @if (!onGoingCards.Any()) { <p class="text-muted small text-center mt-3 empty-col-hint">None</p> }
                </div>
            </div>
        </div>

        @* ── Completed ── *@
        <div class="col">
            <div class="card h-100" style="min-width:220px">
                <div class="card-header d-flex align-items-center gap-2 bg-success bg-opacity-10">
                    <span class="badge bg-success">Done</span>
                    <span class="fw-semibold">Completed</span>
                    <span class="badge bg-success rounded-pill ms-auto" id="count-Completed">@completedCards.Count</span>
                </div>
                <div id="col-Completed" class="card-body p-2 d-flex flex-column gap-2 kanban-col" data-status="Completed" style="min-height:80px">
                    @foreach (var r in completedCards) { @await Html.PartialAsync("_InternalBoardCard", r) }
                    @if (!completedCards.Any()) { <p class="text-muted small text-center mt-3 empty-col-hint">No completed requests</p> }
                </div>
            </div>
        </div>

    </div><!-- /row -->
</div><!-- /container -->

@* ── New Internal Request Modal ─────────────────────────────────────────── *@
<div class="modal fade" id="newInternalRequestModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bx bx-plus-circle me-2"></i>New Internal Request</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateInternalRequest" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label form-label-sm">Brand <span class="text-danger">*</span></label>
                            <select name="brandId" class="form-select form-select-sm" required>
                                <option value="">— select brand —</option>
                                @foreach (var b in brands)
                                {
                                    <option value="@b.Id">@b.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label form-label-sm">Request Type <span class="text-danger">*</span></label>
                            <select name="requestTypeId" id="intReqType" class="form-select form-select-sm" required>
                                <option value="">— select type —</option>
                                @foreach (var t in types)
                                {
                                    <option value="@t.Id" data-isother="@t.IsOther.ToString().ToLower()">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label form-label-sm">Client ID <span class="text-muted">(optional)</span></label>
                            <input type="text" name="clientId" class="form-control form-control-sm"
                                   maxlength="100" placeholder="e.g. 123456" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label form-label-sm">Team Allocation <span class="text-muted">(optional)</span></label>
                            <select name="teamId" class="form-select form-select-sm">
                                <option value="">— no specific team —</option>
                                @foreach (var t in teams)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label form-label-sm">
                                Description / Question
                                <span id="intDescHint" class="text-muted">(optional — max 500 chars)</span>
                            </label>
                            <textarea name="customDescription" id="intDescription" class="form-control form-control-sm"
                                      rows="4" maxlength="500"
                                      placeholder="Describe the issue, ask a question, e.g. How do I reset the 2FA for this player?…"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── Per-card modals ─────────────────────────────────────────────────────── *@
@foreach (var r in requests)
{
    @* Status move modal *@
    <div class="modal fade" id="intStatusModal-@r.Id" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Move card #@r.Id</h6>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body d-grid gap-2">
                    @foreach (var s in Enum.GetValues<CsRequestStatus>())
                    {
                        if (s == r.Status || s == CsRequestStatus.Completed) continue;
                        <form asp-action="InternalUpdateStatus" asp-route-id="@r.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="status" value="@s" />
                            <button type="submit" class="btn btn-outline-secondary btn-sm w-100">→ @s</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Comment modal *@
    <div class="modal fade" id="intCommentModal-@r.Id" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Thread — #@r.Id @(r.IsInternal ? "(Internal)" : "")</h6>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="InternalAddComment" asp-route-id="@r.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        @if (r.Comments.Any(c => c.IsCsInternalOnly))
                        {
                            <div class="mb-3 border rounded p-2 small" style="max-height:200px;overflow-y:auto">
                                @foreach (var c in r.Comments.Where(c => c.IsCsInternalOnly).OrderBy(c => c.CreatedAt))
                                {
                                    <div class="mb-1 @(c.IsSystemMessage ? "text-muted fst-italic" : "")">
                                        <span class="fw-semibold">@c.CreatedAt.ToString("MMM dd HH:mm"):</span> @c.Body
                                    </div>
                                }
                            </div>
                        }
                        <textarea name="body" class="form-control form-control-sm" rows="3"
                                  placeholder="Your comment…" maxlength="1000" required></textarea>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary btn-sm">Post</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* Resolve Escalation modal — TL/Manager only *@
    @if (isTlManager && r.Status == CsRequestStatus.Escalated)
    {
        <div class="modal fade" id="intResolveModal-@r.Id" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h6 class="modal-title">Resolve escalation #@r.Id?</h6>
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body small">Marks the card Completed and posts a system comment.</div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <form asp-action="ResolveEscalation" asp-route-id="@r.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success btn-sm">Resolve</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        // Mark description required only when IsOther type is selected
        document.getElementById('intReqType')?.addEventListener('change', function () {
            const opt = this.options[this.selectedIndex];
            const isOther = opt.dataset.isother === 'true';
            const ta   = document.getElementById('intDescription');
            const hint = document.getElementById('intDescHint');
            if (ta)   ta.required = isOther;
            if (hint) hint.textContent = isOther
                ? '(required for this type — max 500 chars)'
                : '(optional — max 500 chars)';
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script>
    // Fix duplication bug: tell shared cslivehelp.js to use the internal card partial
    window.csCardPartialUrl = '/CsLiveHelp/InternalCardPartial/';
    </script>
    <script>
    (function () {
        'use strict';

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        function showToastMsg(msg, success) {
            if (typeof showToast === 'function') { showToast(msg, success); return; }
            console[success ? 'info' : 'warn']('[AllBrands]', msg);
        }

        // ── Filter ────────────────────────────────────────────────────────
        const brandSel    = document.getElementById('allBrandsBrandFilter');
        const clientInput = document.getElementById('allBrandsClientIdFilter');
        const applyBtn    = document.getElementById('allBrandsFilterApply');
        const clearBtn    = document.getElementById('allBrandsFilterClear');

        function applyFilter() {
            const brandId = brandSel?.value ?? '';
            const query   = (clientInput?.value ?? '').toLowerCase().trim();
            document.querySelectorAll('.kanban-col [data-card-id]').forEach(function (card) {
                const matchBrand  = !brandId || String(card.dataset.brandId) === brandId;
                const matchClient = !query   || (card.dataset.clientId ?? '').includes(query);
                card.style.display = (matchBrand && matchClient) ? '' : 'none';
            });
        }
        applyBtn?.addEventListener('click', applyFilter);
        clientInput?.addEventListener('keydown', function (e) { if (e.key === 'Enter') applyFilter(); });
        clearBtn?.addEventListener('click', function () {
            if (brandSel)    brandSel.value    = '';
            if (clientInput) clientInput.value = '';
            document.querySelectorAll('.kanban-col [data-card-id]').forEach(function (card) {
                card.style.display = '';
            });
        });

        // ── Column count helper ───────────────────────────────────────────
        function updateColCount(status) {
            const col   = document.getElementById('col-' + status);
            const badge = document.getElementById('count-' + status);
            if (col && badge) badge.textContent = col.querySelectorAll('[data-card-id]').length;
        }

        function removeEmptyHint(col) {
            col?.querySelectorAll('.empty-col-hint').forEach(el => el.remove());
        }

        function addEmptyHintIfEmpty(col) {
            if (col && col.querySelectorAll('[data-card-id]').length === 0 && !col.querySelector('.empty-col-hint')) {
                const p = document.createElement('p');
                p.className = 'text-muted small text-center mt-3 empty-col-hint';
                p.textContent = 'None';
                col.appendChild(p);
            }
        }

        const badgeClass = {
            Open:       'bg-secondary',
            InProgress: 'bg-warning text-dark',
            OnGoing:    'bg-warning text-dark',
            Escalated:  'bg-danger',
            Completed:  'bg-success'
        };

        document.querySelectorAll('.kanban-col').forEach(function (col) {
            Sortable.create(col, {
                group:      'int-kanban',
                animation:  150,
                ghostClass: 'sortable-ghost',
                dragClass:  'sortable-drag',
                filter:     'button, a, input, textarea',
                preventOnFilter: false,
                onEnd: async function (evt) {
                    const card      = evt.item;
                    const cardId    = card.dataset.cardId;
                    const newStatus = evt.to.dataset.status;
                    const oldStatus = evt.from.dataset.status;

                    if (!cardId || !newStatus || newStatus === oldStatus) return;

                    removeEmptyHint(evt.to);

                    try {
                        const fd = new FormData();
                        fd.append('status', newStatus);
                        fd.append('__RequestVerificationToken', token);

                        const res = await fetch(`/CsLiveHelp/InternalUpdateStatusJson/${cardId}`, {
                            method: 'POST',
                            body:   fd,
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });

                        if (res.ok) {
                            const badge = card.querySelector('.badge');
                            if (badge && badgeClass[newStatus]) {
                                badge.className = 'badge ' + badgeClass[newStatus];
                                badge.textContent = newStatus;
                            }
                            addEmptyHintIfEmpty(evt.from);
                            updateColCount(newStatus);
                            updateColCount(oldStatus);
                            showToastMsg('Card moved to ' + newStatus, true);
                        } else {
                            evt.from.insertBefore(card, evt.from.children[evt.oldIndex] ?? null);
                            showToastMsg('Failed to update card status.', false);
                        }
                    } catch (_) {
                        evt.from.insertBefore(card, evt.from.children[evt.oldIndex] ?? null);
                        showToastMsg('Network error — card move reverted.', false);
                    }
                }
            });
        });

        // Highlight drop target while dragging
        document.addEventListener('dragover', function (e) {
            const col = e.target.closest('.kanban-col');
            document.querySelectorAll('.kanban-col').forEach(c => c.classList.remove('drag-over'));
            if (col) col.classList.add('drag-over');
        });
        document.addEventListener('dragleave', function (e) {
            if (!e.relatedTarget?.closest('.kanban-col'))
                document.querySelectorAll('.kanban-col').forEach(c => c.classList.remove('drag-over'));
        });
        document.addEventListener('drop', function () {
            document.querySelectorAll('.kanban-col').forEach(c => c.classList.remove('drag-over'));
        });
    })();
    </script>
    <style>
        .sortable-ghost  { opacity: .4; background: #e8f4ff; border: 2px dashed #0d6efd !important; }
        .sortable-drag   { box-shadow: 0 6px 20px rgba(0,0,0,.2); }
        .kanban-col      { transition: background .15s; }
        .kanban-col .card { cursor: grab; }
        .kanban-col .card:active { cursor: grabbing; }
        .drag-over       { background: rgba(13,110,253,.06) !important; border: 2px dashed #0d6efd; border-radius: .375rem; }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script src="~/js/cslivehelp.js"></script>
}
