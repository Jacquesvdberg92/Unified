@using Unified.Models.CsLiveHelp
@model CsRequest
@{
    var isResetPassword = Model.RequestType?.Name == "Reset Password";
    var isEscalated     = Model.Status == CsRequestStatus.Escalated;
    var teamAllocationTeams = (List<Unified.Models.Identity.Team>)ViewBag.TeamAllocationTeams;
}

@* Status modal *@
<div class="modal fade" id="statusModal-@Model.Id" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Move card #@Model.Id</h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body d-grid gap-2">
                @foreach (var s in Enum.GetValues<CsRequestStatus>())
                {
                    if (s == Model.Status) continue;
                    <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="status" value="@s" />
                        <button type="submit" class="btn btn-outline-secondary btn-sm w-100">→ @s</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@* Comment modal *@
<div class="modal fade" id="csCommentModal-@Model.Id" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title"><i class="bx bx-message-square-detail me-1"></i>Thread — #@Model.Id · @(Model.Brand?.Name ?? "—")</h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CsAddComment" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    @if (Model.Comments.Any())
                    {
                        <div class="thread-body mb-3 border rounded p-2 small" style="max-height:220px;overflow-y:auto">
                            @foreach (var c in Model.Comments)
                            {
                                <div class="mb-2 @(c.IsSystemMessage ? "text-muted fst-italic" : "")">
                                    <div class="d-flex gap-1 align-items-center mb-1" style="font-size:.7rem">
                                        @if (c.IsSystemMessage)
                                        {
                                            <span class="badge bg-secondary" style="font-size:.65rem">System</span>
                                        }
                                        else
                                        {
                                            <span class="fw-semibold">@(c.Author?.DisplayName ?? c.Author?.UserName ?? "—")</span>
                                        }
                                        <span class="text-muted">@c.CreatedAt.ToString("MMM dd, HH:mm") UTC</span>
                                    </div>
                                    <div>@c.Body</div>
                                    @if (!string.IsNullOrWhiteSpace(c.ImagePath))
                                    {
                                        <div class="mt-1">
                                            <a href="@c.ImagePath" target="_blank" rel="noopener">
                                                <img src="@c.ImagePath" alt="Attachment" class="img-fluid rounded" style="max-height:180px" />
                                            </a>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="thread-body mb-3 border rounded p-2 small text-muted" style="max-height:220px;overflow-y:auto">
                            <p class="mb-0">No comments yet.</p>
                        </div>
                    }
                    <textarea name="body" class="form-control form-control-sm" rows="3"
                              placeholder="Write a reply…" maxlength="1000" required></textarea>
                    <div class="mt-2">
                        <input type="file" name="image" class="form-control form-control-sm"
                               accept="image/jpeg,image/png,image/gif,image/webp" />
                        <div class="form-text">Optional · jpg/png/gif/webp · max 5 MB</div>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bx bx-send me-1"></i>Post reply</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Escalate modal *@
<div class="modal fade" id="escalateModal-@Model.Id" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Escalate card #@Model.Id?</h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Escalate" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <p class="small mb-2">This will move the card to the Escalated column.</p>
                    <label class="form-label form-label-sm">Team allocation <span class="text-danger">*</span></label>
                    <select name="assignedTeamId" class="form-select form-select-sm" required>
                        <option value="">— select team —</option>
                        @foreach (var t in teamAllocationTeams)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger btn-sm">Escalate</button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (isResetPassword && Model.Status != CsRequestStatus.Completed)
{
    @* Send Reset modal *@
    <div class="modal fade" id="resetModal-@Model.Id" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Send reset — #@Model.Id?</h6>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body small">Posts <em>"Password reset to Aa123456"</em> and marks card Completed.</div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="SendReset" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-warning btn-sm">Send Reset</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@if (isEscalated)
{
    @* Mark Passed modal *@
    <div class="modal fade" id="passedModal-@Model.Id" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Mark passed — #@Model.Id?</h6>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body small">Posts <em>"Passed to relevant agents"</em> and marks card Completed.</div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="MarkPassed" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success btn-sm">Mark Passed</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
