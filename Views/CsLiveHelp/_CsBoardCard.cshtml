@using Unified.Models.CsLiveHelp
@model CsRequest
@{
    var statusBadge = Model.Status switch
    {
        CsRequestStatus.Open       => "bg-secondary",
        CsRequestStatus.InProgress => "bg-warning text-dark",
        CsRequestStatus.OnGoing    => "bg-warning text-dark",
        CsRequestStatus.Completed  => "bg-success",
        CsRequestStatus.Escalated  => "bg-danger",
        _                          => "bg-secondary"
    };
    var isResetPassword = Model.RequestType?.Name == "Reset Password";
    var isSimulatePoi   = Model.RequestType?.Name == "Simulate POI";
    var isEscalated     = Model.Status == CsRequestStatus.Escalated;
    var assignedName    = Model.AssignedTo?.DisplayName ?? Model.AssignedTo?.UserName;
}

<div class="card border shadow-sm p-2 small" data-card-id="@Model.Id" data-card-status="@Model.Status" data-brand-id="@Model.BrandId" data-client-id="@Model.ClientId?.ToLower()">
    <div class="d-flex justify-content-between align-items-start mb-1">
        <span class="badge @statusBadge">@Model.Status</span>
        <span class="text-muted" style="font-size:.75rem">#@Model.Id</span>
    </div>
    <div class="fw-semibold">@(Model.Brand?.Name ?? "—")</div>
    <div class="text-muted">@(Model.RequestType?.Name ?? "—")</div>
    @if (!string.IsNullOrWhiteSpace(Model.ClientId))
    {
        <div class="text-muted mt-1 d-flex align-items-center gap-1" style="font-size:.72rem">
            <i class="bx bx-id-card"></i>
            <span class="fw-semibold">@Model.ClientId</span>
            <button type="button"
                    class="btn btn-outline-secondary btn-sm py-0 px-1 copy-client-id-btn"
                    data-client-id="@Model.ClientId"
                    title="Copy Client ID"
                    aria-label="Copy Client ID">
                <i class="bx bx-copy"></i>
            </button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.CustomDescription))
    {
        <div class="text-muted mt-1" style="font-size:.75rem; white-space:pre-wrap">@Model.CustomDescription</div>
    }
    @if (assignedName is not null)
    {
        <div class="text-muted mt-1" style="font-size:.72rem">
            <i class="bx bx-user-check me-1"></i>Picked by: <span class="cs-assigned-name fw-semibold">@assignedName</span>
        </div>
    }
    @{
        var visibleCount = Model.Comments.Count(c => !c.IsCsInternalOnly);
    }
    <div class="mt-1">
        <button class="btn btn-link btn-sm p-0 text-muted comment-count-btn"
                style="font-size:.72rem;@(visibleCount > 0 ? "" : "display:none")"
                data-bs-toggle="modal"
                data-bs-target="#csCommentModal-@Model.Id"
                title="View thread">
            <i class="bx bx-comment me-1"></i><span class="comment-count">@visibleCount</span> comment(s) — View thread
        </button>
    </div>
    <div class="text-muted mt-1" style="font-size:.72rem">@Model.CreatedAt.ToString("MMM dd, HH:mm") UTC</div>

    <div class="d-flex gap-1 mt-2 flex-wrap">
        @* Move status — hidden when drag-drop is active, kept as fallback *@
        <button class="btn btn-outline-secondary btn-sm py-0 px-2 cs-move-btn"
                data-bs-toggle="modal"
                data-bs-target="#statusModal-@Model.Id"
                title="Move">
            <i class="bx bx-transfer-alt"></i>
        </button>

        @* View thread / Comment *@
        <button class="btn btn-outline-primary btn-sm py-0 px-2"
                data-bs-toggle="modal"
                data-bs-target="#csCommentModal-@Model.Id"
                title="View thread &amp; comment">
            <i class="bx bx-message-square-detail"></i>
        </button>

        @* Escalate (only when not already escalated or completed) *@
        @if (Model.Status != CsRequestStatus.Escalated && Model.Status != CsRequestStatus.Completed)
        {
            <button class="btn btn-outline-danger btn-sm py-0 px-2"
                    data-bs-toggle="modal"
                    data-bs-target="#escalateModal-@Model.Id"
                    title="Escalate">
                <i class="bx bx-error-circle"></i>
            </button>
        }

        @* Smart: Log Simulation — opens POI modal pre-populated with this card's brand *@
        @if (isSimulatePoi)
        {
            <button class="btn btn-outline-info btn-sm py-0 px-2"
                    data-modal-src="/PoiSimulation/LogPartialWithBrand?brandId=@Model.BrandId"
                    data-bs-target="#poiLogModal"
                    title="Log Simulation">
                <i class="bx bx-log-in-circle"></i>
            </button>
        }

        @* Smart: Send Reset *@
        @if (isResetPassword && Model.Status != CsRequestStatus.Completed)
        {
            <button class="btn btn-outline-warning btn-sm py-0 px-2"
                    data-bs-toggle="modal"
                    data-bs-target="#resetModal-@Model.Id"
                    title="Send Reset">
                <i class="bx bx-key"></i>
            </button>
        }

        @* Smart: Mark Passed (only on escalated cards) *@
        @if (isEscalated)
        {
            <button class="btn btn-outline-success btn-sm py-0 px-2"
                    data-bs-toggle="modal"
                    data-bs-target="#passedModal-@Model.Id"
                    title="Mark Passed">
                <i class="bx bx-check-double"></i>
            </button>
        }
    </div>
</div>
