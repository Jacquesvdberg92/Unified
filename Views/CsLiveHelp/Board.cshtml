@using Unified.Models.CsLiveHelp
@*
    ── CS LIVE HELP: BOARD PAGE ────────────────────────────────────────────

    ARCHITECTURE REFERENCE: See docs/CsLiveHelp-Architecture.md for:
    - Overview of all three CS Live Help pages and their relationships
    - SignalR real-time update flow and group routing
    - Role-based access control and data visibility rules
    - Expected behavior of drag-drop assignments, comment posting, and live card updates

    This page shows all non-internal requests in a 5-column kanban board.
    Drag-drop to change status; assignments persist via UpdateStatusJson.
    Public comments are visible to both CS and assigned AMs via SignalR.
*@
@{
    ViewData["Title"] = "CS Live Help Board";
    var requests = (List<CsRequest>)ViewBag.Requests;
    var teamAllocationTeams = (List<Unified.Models.Identity.Team>)ViewBag.TeamAllocationTeams;

    var openCards       = requests.Where(r => r.Status == CsRequestStatus.Open).ToList();
    var inProgressCards = requests.Where(r => r.Status == CsRequestStatus.InProgress).ToList();
    var onGoingCards    = requests.Where(r => r.Status == CsRequestStatus.OnGoing).ToList();
    var escalatedCards  = requests.Where(r => r.Status == CsRequestStatus.Escalated).ToList();
    var completedCards  = requests.Where(r => r.Status == CsRequestStatus.Completed).ToList();
}

<div class="container-fluid">

    @if (TempData["Error"] is string err)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bx bx-error-circle me-2"></i>@err
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bx bx-check-circle me-2"></i>@ok
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div id="csBroadcastBannerHost" class="mb-3" style="display:none"></div>

    <div class="d-flex align-items-center mb-3">
        <h5 class="mb-0"><i class="bx bx-support me-2"></i>CS Live Help Board</h5>
        <span class="badge bg-primary ms-3">@requests.Count total</span>
        @if (User.IsInRole(Unified.Models.Identity.Roles.TeamLeader) ||
             User.IsInRole(Unified.Models.Identity.Roles.BrandManager) ||
             User.IsInRole(Unified.Models.Identity.Roles.SwissArmyKnife))
        {
            <button type="button" class="btn btn-outline-warning btn-sm ms-auto"
                    data-bs-toggle="modal" data-bs-target="#broadcastModal">
                <i class="bx bx-megaphone me-1"></i>Broadcast
            </button>
        }
    </div>

    <!-- Filter bar -->
    <div class="d-flex flex-wrap gap-2 mb-3 align-items-center" id="boardFilterBar">
        <select id="boardBrandFilter" class="form-select form-select-sm" style="max-width:200px">
            <option value="">All Brands</option>
            @foreach (var b in (List<Unified.Models.EmailTemplates.Brand>)ViewBag.Brands)
            {
                <option value="@b.Id">@b.Name</option>
            }
        </select>
        <input id="boardClientIdFilter" type="search" class="form-control form-control-sm" style="max-width:180px"
               placeholder="Search Client ID…" autocomplete="off" />
        <button type="button" class="btn btn-primary btn-sm" id="boardFilterApply">
            <i class="bx bx-filter-alt me-1"></i>Apply
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="boardFilterClear">
            <i class="bx bx-x me-1"></i>Clear
        </button>
    </div>

    <!-- Kanban board – 5 columns -->
    @* Hidden antiforgery token used by drag-drop fetch *@
    @Html.AntiForgeryToken()
    <div class="row g-3">

        @* ── Open ── *@
        <div class="col">
            <div class="card h-100" style="min-width:220px">
                <div class="card-header d-flex align-items-center gap-2 bg-secondary bg-opacity-10">
                    <span class="badge bg-secondary">Open</span>
                    <span class="fw-semibold">Open</span>
                    <span class="badge bg-secondary rounded-pill ms-auto" id="count-Open">@openCards.Count</span>
                </div>
                <div id="col-Open" class="card-body p-2 d-flex flex-column gap-2 kanban-col" data-status="Open" style="min-height:80px">
                    @foreach (var r in openCards)
                    {
                        @await Html.PartialAsync("_CsBoardCard", r)
                    }
                    @if (!openCards.Any())
                    {
                        <p class="text-muted small text-center mt-3 empty-col-hint">No open requests</p>
                    }
                    @if (openCards.Count == 50)
                    {
                        <div class="load-more-row mt-auto pt-2">
                            <button class="btn btn-outline-secondary btn-sm w-100 load-more-btn"
                                    data-status="Open"
                                    data-after-id="@openCards.Last().Id">Load more</button>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── In Progress ── *@
        <div class="col">
            <div class="card h-100" style="min-width:220px">
                <div class="card-header d-flex align-items-center gap-2 bg-warning bg-opacity-10">
                    <span class="badge bg-warning text-dark">InProgress</span>
                    <span class="fw-semibold">In Progress</span>
                    <span class="badge bg-warning text-dark rounded-pill ms-auto" id="count-InProgress">@inProgressCards.Count</span>
                </div>
                <div id="col-InProgress" class="card-body p-2 d-flex flex-column gap-2 kanban-col" data-status="InProgress" style="min-height:80px">
                    @foreach (var r in inProgressCards)
                    {
                        @await Html.PartialAsync("_CsBoardCard", r)
                    }
                    @if (!inProgressCards.Any())
                    {
                        <p class="text-muted small text-center mt-3 empty-col-hint">None</p>
                    }
                    @if (inProgressCards.Count == 50)
                    {
                        <div class="load-more-row mt-auto pt-2">
                            <button class="btn btn-outline-secondary btn-sm w-100 load-more-btn"
                                    data-status="InProgress"
                                    data-after-id="@inProgressCards.Last().Id">Load more</button>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── On Going ── *@
        <div class="col">
            <div class="card h-100" style="min-width:220px">
                <div class="card-header d-flex align-items-center gap-2 bg-warning bg-opacity-10">
                    <span class="badge bg-warning text-dark">OnGoing</span>
                    <span class="fw-semibold">On Going</span>
                    <span class="badge bg-warning text-dark rounded-pill ms-auto" id="count-OnGoing">@onGoingCards.Count</span>
                </div>
                <div id="col-OnGoing" class="card-body p-2 d-flex flex-column gap-2 kanban-col" data-status="OnGoing" style="min-height:80px">
                    @foreach (var r in onGoingCards)
                    {
                        @await Html.PartialAsync("_CsBoardCard", r)
                    }
                    @if (!onGoingCards.Any())
                    {
                        <p class="text-muted small text-center mt-3 empty-col-hint">None</p>
                    }
                    @if (onGoingCards.Count == 50)
                    {
                        <div class="load-more-row mt-auto pt-2">
                            <button class="btn btn-outline-secondary btn-sm w-100 load-more-btn"
                                    data-status="OnGoing"
                                    data-after-id="@onGoingCards.Last().Id">Load more</button>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Escalated ── *@
        <div class="col">
            <div class="card h-100" style="min-width:220px">
                <div class="card-header d-flex align-items-center gap-2 bg-danger bg-opacity-10">
                    <span class="badge bg-danger">Escalated</span>
                    <span class="fw-semibold">Escalated</span>
                    <span class="badge bg-danger rounded-pill ms-auto" id="count-Escalated">@escalatedCards.Count</span>
                </div>
                <div id="col-Escalated" class="card-body p-2 d-flex flex-column gap-2 kanban-col" data-status="Escalated" style="min-height:80px">
                    @foreach (var r in escalatedCards)
                    {
                        @await Html.PartialAsync("_CsBoardCard", r)
                    }
                    @if (!escalatedCards.Any())
                    {
                        <p class="text-muted small text-center mt-3 empty-col-hint">None</p>
                    }
                    @if (escalatedCards.Count == 50)
                    {
                        <div class="load-more-row mt-auto pt-2">
                            <button class="btn btn-outline-secondary btn-sm w-100 load-more-btn"
                                    data-status="Escalated"
                                    data-after-id="@escalatedCards.Last().Id">Load more</button>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Completed ── *@
        <div class="col">
            <div class="card h-100" style="min-width:220px">
                <div class="card-header d-flex align-items-center gap-2 bg-success bg-opacity-10">
                    <span class="badge bg-success">Done</span>
                    <span class="fw-semibold">Completed</span>
                    <span class="badge bg-success rounded-pill ms-auto" id="count-Completed">@completedCards.Count</span>
                </div>
                <div id="col-Completed" class="card-body p-2 d-flex flex-column gap-2 kanban-col" data-status="Completed" style="min-height:80px">
                    @foreach (var r in completedCards)
                    {
                        @await Html.PartialAsync("_CsBoardCard", r)
                    }
                    @if (!completedCards.Any())
                    {
                        <p class="text-muted small text-center mt-3 empty-col-hint">None</p>
                    }
                    @if (completedCards.Count == 50)
                    {
                        <div class="load-more-row mt-auto pt-2">
                            <button class="btn btn-outline-secondary btn-sm w-100 load-more-btn"
                                    data-status="Completed"
                                    data-after-id="@completedCards.Last().Id">Load more</button>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div><!-- /row -->
</div><!-- /container -->

@* ──────────────────────────────────────────────────────────────────────────
   Per-card modals (status, comment, escalate, smart actions)
   ─────────────────────────────────────────────────────────────────────── *@
@foreach (var r in requests)
{
    @* Status modal *@
    <div class="modal fade" id="statusModal-@r.Id" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Move card #@r.Id</h6>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body d-grid gap-2">
                    @foreach (var s in Enum.GetValues<CsRequestStatus>())
                    {
                        if (s == r.Status) continue;
                        <form asp-action="UpdateStatus" asp-route-id="@r.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="status" value="@s" />
                            <button type="submit" class="btn btn-outline-secondary btn-sm w-100">→ @s</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Comment modal *@
    <div class="modal fade" id="csCommentModal-@r.Id" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title"><i class="bx bx-message-square-detail me-1"></i>Thread — #@r.Id · @(r.Brand?.Name ?? "—")</h6>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="CsAddComment" asp-route-id="@r.Id" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        @if (r.Comments.Any(c => !c.IsCsInternalOnly))
                        {
                            <div class="thread-body mb-3 border rounded p-2 small" style="max-height:220px;overflow-y:auto">
                                @foreach (var c in r.Comments.Where(c => !c.IsCsInternalOnly).OrderBy(c => c.CreatedAt))
                                {
                                    <div class="mb-2 @(c.IsSystemMessage ? "text-muted fst-italic" : "")">
                                        <div class="d-flex gap-1 align-items-center mb-1" style="font-size:.7rem">
                                            @if (c.IsSystemMessage)
                                            {
                                                <span class="badge bg-secondary" style="font-size:.65rem">System</span>
                                            }
                                            else
                                            {
                                                <span class="fw-semibold">@(c.Author?.DisplayName ?? c.Author?.UserName ?? "—")</span>
                                            }
                                            <span class="text-muted">@c.CreatedAt.ToString("MMM dd, HH:mm") UTC</span>
                                        </div>
                                        <div>@c.Body</div>
                                        @if (!string.IsNullOrWhiteSpace(c.ImagePath))
                                        {
                                            <div class="mt-1">
                                                <a href="@c.ImagePath" target="_blank" rel="noopener">
                                                    <img src="@c.ImagePath" alt="Attachment" class="img-fluid rounded" style="max-height:180px" />
                                                </a>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="thread-body mb-3 border rounded p-2 small text-muted" style="max-height:220px;overflow-y:auto">
                                <p class="mb-0">No comments yet.</p>
                            </div>
                        }
                        @if (r.Comments.Any(c => c.IsCsInternalOnly))
                        {
                            <div class="alert alert-secondary py-1 px-2 small mb-2">
                                <i class="bx bx-lock me-1"></i>This card has <strong>@r.Comments.Count(c => c.IsCsInternalOnly)</strong> CS-internal note(s) not shown here.
                            </div>
                        }
                        <textarea name="body" class="form-control form-control-sm" rows="3"
                                  placeholder="Write a reply…" maxlength="1000" required></textarea>
                        <div class="mt-2">
                            <input type="file" name="image" class="form-control form-control-sm"
                                   accept="image/jpeg,image/png,image/gif,image/webp" />
                            <div class="form-text">Optional · jpg/png/gif/webp · max 5 MB</div>
                        </div>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary btn-sm"><i class="bx bx-send me-1"></i>Post reply</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* Escalate modal *@
    <div class="modal fade" id="escalateModal-@r.Id" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <form asp-action="Escalate" asp-route-id="@r.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header py-2">
                        <h6 class="modal-title">Escalate card #@r.Id?</h6>
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="small mb-2">This will move the card to the Escalated column.</p>
                        <label class="form-label form-label-sm">Team allocation <span class="text-danger">*</span></label>
                        <select name="assignedTeamId" class="form-select form-select-sm" required>
                            <option value="">— select team —</option>
                            @foreach (var t in teamAllocationTeams)
                            {
                                <option value="@t.Id">@t.Name</option>
                            }
                        </select>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger btn-sm">Escalate</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (r.RequestType?.Name == "Reset Password")
    {
        @* Send Reset modal *@
        <div class="modal fade" id="resetModal-@r.Id" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h6 class="modal-title">Send reset — #@r.Id?</h6>
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body small">Posts <em>"Password reset to Aa123456"</em> and marks card Completed.</div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <form asp-action="SendReset" asp-route-id="@r.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-warning btn-sm">Send Reset</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (r.Status == CsRequestStatus.Escalated)
    {
        @* Mark Passed modal *@
        <div class="modal fade" id="passedModal-@r.Id" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h6 class="modal-title">Mark passed — #@r.Id?</h6>
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body small">Posts <em>"Passed to relevant agents"</em> and marks card Completed.</div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <form asp-action="MarkPassed" asp-route-id="@r.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success btn-sm">Mark Passed</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}

@* ── Shared POI Log modal (opened by data-modal-src on Simulate POI cards) ── *@
<div class="modal fade" id="poiLogModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bx bx-id-card me-2"></i>Log POI Simulation</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (User.IsInRole(Unified.Models.Identity.Roles.TeamLeader) ||
     User.IsInRole(Unified.Models.Identity.Roles.BrandManager) ||
     User.IsInRole(Unified.Models.Identity.Roles.SwissArmyKnife))
{
    <div class="modal fade" id="broadcastModal" tabindex="-1" aria-labelledby="broadcastModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="broadcastForm">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h6 class="modal-title" id="broadcastModalLabel"><i class="bx bx-megaphone me-2"></i>Broadcast Reminder</h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label for="broadcastMessage" class="form-label fw-semibold">Message</label>
                        <textarea id="broadcastMessage" class="form-control" rows="4" maxlength="300"
                                  placeholder="Write a reminder for Account Managers..." required></textarea>
                        <div class="form-text text-end"><span id="broadcastMessageCount">0</span>/300</div>
                        <div id="broadcastError" class="text-danger small mt-2" style="display:none"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning btn-sm" id="broadcastSendBtn">
                            <i class="bx bx-send me-1"></i>Send Broadcast
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
    (function () {
        'use strict';

        const form = document.getElementById('broadcastForm');
        const msgInput = document.getElementById('broadcastMessage');
        const msgCount = document.getElementById('broadcastMessageCount');
        const sendBtn = document.getElementById('broadcastSendBtn');
        const errBox = document.getElementById('broadcastError');
        const modalEl = document.getElementById('broadcastModal');

        if (!form || !msgInput) return;

        msgInput.addEventListener('input', function () {
            msgCount.textContent = String(this.value.length);
        });

        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            errBox.style.display = 'none';
            const message = msgInput.value.trim();
            if (!message) {
                errBox.textContent = 'Message is required.';
                errBox.style.display = '';
                return;
            }

            const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            const fd = new FormData();
            fd.append('__RequestVerificationToken', token);
            fd.append('message', message);

            sendBtn.disabled = true;
            sendBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending...';

            try {
                const res = await fetch('/CsLiveHelp/BroadcastBanner', {
                    method: 'POST',
                    body: fd,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await res.json();
                if (!res.ok || !data.success) {
                    errBox.textContent = data.error ?? 'Failed to send broadcast.';
                    errBox.style.display = '';
                    return;
                }

                msgInput.value = '';
                msgCount.textContent = '0';
                if (window.bootstrap && modalEl) {
                    bootstrap.Modal.getOrCreateInstance(modalEl).hide();
                }
            } catch (_) {
                errBox.textContent = 'Network error while sending broadcast.';
                errBox.style.display = '';
            } finally {
                sendBtn.disabled = false;
                sendBtn.innerHTML = '<i class="bx bx-send me-1"></i>Send Broadcast';
            }
        });
    })();
    </script>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script>
(function () {
    'use strict';

    // ── Board filter ──────────────────────────────────────────────────────
    const brandSel    = document.getElementById('boardBrandFilter');
    const clientInput = document.getElementById('boardClientIdFilter');
    const applyBtn    = document.getElementById('boardFilterApply');
    const clearBtn    = document.getElementById('boardFilterClear');

    function applyFilter() {
        const brandId = brandSel?.value ?? '';
        const query   = (clientInput?.value ?? '').toLowerCase().trim();
        document.querySelectorAll('.kanban-col [data-card-id]').forEach(function (card) {
            const matchBrand  = !brandId || String(card.dataset.brandId) === brandId;
            const matchClient = !query   || (card.dataset.clientId ?? '').includes(query);
            card.style.display = (matchBrand && matchClient) ? '' : 'none';
        });
    }

    applyBtn?.addEventListener('click', applyFilter);
    clientInput?.addEventListener('keydown', function (e) { if (e.key === 'Enter') applyFilter(); });
    clearBtn?.addEventListener('click', function () {
        if (brandSel)    brandSel.value    = '';
        if (clientInput) clientInput.value = '';
        document.querySelectorAll('.kanban-col [data-card-id]').forEach(function (card) {
            card.style.display = '';
        });
    });

    // ── Column count helper ───────────────────────────────────────────────
    function updateColCount(status) {
        const col = document.getElementById('col-' + status);
        const badge = document.getElementById('count-' + status);
        if (col && badge) badge.textContent = col.querySelectorAll('[data-card-id]').length;
    }

    // Antiforgery token injected by @Html.AntiForgeryToken() in the board
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

    function showToastMsg(msg, success) {
        // reuse dashboard-widgets toast if available, otherwise alert
        if (typeof showToast === 'function') { showToast(msg, success); return; }
        if (!success) console.error(msg);
    }

    // Initialise SortableJS on every kanban column
    document.querySelectorAll('.kanban-col').forEach(function (col) {
        Sortable.create(col, {
            group:     'kanban',          // cards can move between all columns
            animation: 150,
            ghostClass: 'sortable-ghost',
            dragClass:  'sortable-drag',
            filter:    'button, a, input, textarea, .modal', // don't drag when clicking buttons
            preventOnFilter: false,
            onEnd: async function (evt) {
                const card       = evt.item;
                const cardId     = card.dataset.cardId;
                const newStatus  = evt.to.dataset.status;
                const oldStatus  = evt.from.dataset.status;

                if (!cardId || !newStatus || newStatus === oldStatus) return;

                // Remove empty-column hint from target col
                evt.to.querySelectorAll('.empty-col-hint').forEach(el => el.remove());

                try {
                    const fd = new FormData();
                    fd.append('status', newStatus);
                    fd.append('__RequestVerificationToken', token);

                    const res = await fetch(`/CsLiveHelp/UpdateStatusJson/${cardId}`, {
                        method: 'POST',
                        body: fd,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    if (res.ok) {
                        // Update the badge inside the moved card
                        const badge = card.querySelector('.badge');
                        if (badge) {
                            const cls = {
                                Open:       'bg-secondary',
                                InProgress: 'bg-warning text-dark',
                                OnGoing:    'bg-warning text-dark',
                                Escalated:  'bg-danger',
                                Completed:  'bg-success'
                            }[newStatus] ?? 'bg-secondary';
                            badge.className = 'badge ' + cls;
                            badge.textContent = newStatus;
                        }
                        updateColCount(newStatus);
                        updateColCount(oldStatus);
                        showToastMsg('Card moved to ' + newStatus, true);
                    } else {
                        // Revert the DOM move on failure
                        evt.from.insertBefore(card, evt.from.children[evt.oldIndex] ?? null);
                        showToastMsg('Failed to update card status.', false);
                    }
                } catch (_) {
                    evt.from.insertBefore(card, evt.from.children[evt.oldIndex] ?? null);
                    showToastMsg('Network error — card move reverted.', false);
                }
            }
        });
    });

    // Highlight drop target column while dragging
    document.addEventListener('dragover', function (e) {
        const col = e.target.closest('.kanban-col');
        document.querySelectorAll('.kanban-col').forEach(c => c.classList.remove('drag-over'));
        if (col) col.classList.add('drag-over');
    });
    document.addEventListener('dragleave', function (e) {
        if (!e.relatedTarget?.closest('.kanban-col')) {
            document.querySelectorAll('.kanban-col').forEach(c => c.classList.remove('drag-over'));
        }
    });
    document.addEventListener('drop', function () {
        document.querySelectorAll('.kanban-col').forEach(c => c.classList.remove('drag-over'));
    });

    // POI modal loader — triggered by buttons with data-modal-src targeting #poiLogModal
    const poiModal = document.getElementById('poiLogModal');
    if (poiModal) {
        poiModal.addEventListener('show.bs.modal', async function (e) {
            const btn = e.relatedTarget;
            const src = btn?.dataset?.modalSrc;
            if (!src) return;
            const body = poiModal.querySelector('.modal-body');
            body.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>';
            try {
                const res = await fetch(src, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (res.ok) body.innerHTML = await res.text();
                else body.innerHTML = '<p class="text-danger">Failed to load form.</p>';
            } catch (_) {
                body.innerHTML = '<p class="text-danger">Network error.</p>';
            }
        });

        // Clear modal body on close so next open re-fetches
        poiModal.addEventListener('hidden.bs.modal', function () {
            const body = poiModal.querySelector('.modal-body');
            body.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>';
        });
    }
})();
</script>
<style>
    .sortable-ghost  { opacity: .4; background: #e8f4ff; border: 2px dashed #0d6efd !important; }
    .sortable-drag   { box-shadow: 0 6px 20px rgba(0,0,0,.2); }
    .kanban-col      { transition: background .15s; cursor: default; }
    .kanban-col .card { cursor: grab; }
    .kanban-col .card:active { cursor: grabbing; }
    .drag-over       { background: rgba(13,110,253,.06) !important; border: 2px dashed #0d6efd; border-radius: .375rem; }
</style>
<script src="~/js/cslivehelp-mentions.js"></script>
<script src="~/js/cslivehelp.js"></script>
}
