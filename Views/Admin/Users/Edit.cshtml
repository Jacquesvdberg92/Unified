@model Unified.Models.Identity.AppUser
@{
    ViewData["Title"] = "Edit User";
}

<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    <h1 class="page-title fw-semibold fs-18 mb-0">Edit User</h1>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="EditUser" asp-route-id="@Model.Id" method="post">
            <div class="mb-3">
                <label class="form-label">Display Name</label>
                <input name="displayName" value="@Model.DisplayName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input value="@Model.Email" class="form-control" disabled />
            </div>
            <div class="mb-3">
                <label class="form-label">Language</label>
                <input name="language" value="@Model.Language" class="form-control" placeholder="e.g. EN, JP, PT" />
            </div>
            <div class="mb-3">
                <label class="form-label">AnyDesk ID</label>
                <input name="anydeskId" value="@Model.AnydeskId" class="form-control" placeholder="e.g. 123 456 789" />
                <div class="form-text">Used by the &ldquo;Request Login&rdquo; dashboard widget to send the AnyDesk ID to IT via Telegram.</div>
            </div>
            <div class="mb-3 form-check">
                <input class="form-check-input" type="checkbox" name="hasWeekendShift" value="true"
                       @(Model.HasWeekendShift ? "checked" : "") />
                <label class="form-check-label">Has Weekend Shift</label>
            </div>
            <div class="mb-3 form-check">
                <input class="form-check-input" type="checkbox" name="hasCsLiveHelp" value="true"
                       @(Model.HasCsLiveHelp ? "checked" : "") />
                <label class="form-check-label">CS Live Allocation Eligible</label>
            </div>
            <div class="mb-3">
                <label class="form-label">Role</label>
                <select name="role" class="form-select" asp-items="ViewBag.AllRoles"></select>
            </div>
            <div class="mb-3">
                <label class="form-label">Teams</label>
                @foreach (var team in (IEnumerable<Unified.Models.Identity.Team>)ViewBag.AllTeams)
                {
                    var selected = ((int[])ViewBag.SelectedTeams).Contains(team.Id);
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="teamIds" value="@team.Id"
                               @(selected ? "checked" : "") />
                        <label class="form-check-label">@team.Name</label>
                    </div>
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Brands</label>
                @foreach (var brand in (IEnumerable<Unified.Models.EmailTemplates.Brand>)ViewBag.AllBrands)
                {
                    var selected = ((int[])ViewBag.SelectedBrands).Contains(brand.Id);
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="brandIds" value="@brand.Id"
                               @(selected ? "checked" : "") />
                        <label class="form-check-label">@brand.Name</label>
                    </div>
                }
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Users" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
