@model IEnumerable<Unified.Models.Identity.Team>
@{
    ViewData["Title"] = "Teams";
}

<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb gap-3">
    <div>
        <h1 class="page-title fw-semibold fs-18 mb-1">Admin Teams</h1>
        <p class="text-muted mb-0">Manage team names, leaders, and membership.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="CreateTeam" class="btn btn-primary btn-sm">
            <i class="ri-group-line me-1"></i> New Team
        </a>
        <a asp-action="Users" class="btn btn-outline-primary btn-sm">Users</a>
    </div>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a asp-action="Users" class="nav-link">Users</a>
    </li>
    <li class="nav-item">
        <a asp-action="Teams" class="nav-link active">Teams</a>
    </li>
    <li class="nav-item">
        <a asp-action="AccountRequests" class="nav-link">Account Requests</a>
    </li>
</ul>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" data-admin-datatable data-order-column="0" data-order-dir="asc">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Language</th>
                        <th>Team Leader</th>
                        <th>Members</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var team in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@team.Name</td>
                            <td>@(team.Language ?? "—")</td>
                            <td>@(team.TeamLeader?.DisplayName ?? "—")</td>
                            <td><span class="badge bg-secondary">@team.Members.Count</span></td>
                            <td class="text-end">
                                <a asp-action="EditTeam" asp-route-id="@team.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
