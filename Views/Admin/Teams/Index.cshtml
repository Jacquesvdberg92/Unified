@model IEnumerable<Unified.Models.Identity.Team>
@{
    ViewData["Title"] = "Teams";
}

<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    <h1 class="page-title fw-semibold fs-18 mb-0">Admin</h1>
    <a asp-action="CreateTeam" class="btn btn-primary btn-sm">
        <i class="ri-group-line me-1"></i> New Team
    </a>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a asp-action="Users" class="nav-link">Users</a>
    </li>
    <li class="nav-item">
        <a asp-action="Teams" class="nav-link active">Teams</a>
    </li>
</ul>

<div class="card">
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Language</th>
                    <th>Team Leader</th>
                    <th>Members</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var team in Model)
                {
                    <tr>
                        <td>@team.Name</td>
                        <td>@(team.Language ?? "—")</td>
                        <td>@(team.TeamLeader?.DisplayName ?? "—")</td>
                        <td>@team.Members.Count</td>
                        <td>
                            <a asp-action="EditTeam" asp-route-id="@team.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
