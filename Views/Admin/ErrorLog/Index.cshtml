@model Unified.Controllers.AdminErrorLogIndexViewModel
@{
    ViewData["Title"] = "Error Log";
    var totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);
}

<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    <h1 class="page-title fw-semibold fs-18 mb-0">Error Log</h1>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a asp-action="ActivityLog" class="nav-link">Activity Log</a></li>
    <li class="nav-item"><a asp-action="ErrorLog" class="nav-link active">Error Log</a></li>
</ul>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Timestamp (UTC)</th>
                        <th>Exception</th>
                        <th>Path</th>
                        <th>User</th>
                        <th>Message</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No error logs found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>@row.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td><code>@row.ExceptionType</code></td>
                            <td class="text-break">@row.Method @row.Path</td>
                            <td>@(string.IsNullOrWhiteSpace(row.UserId) ? "Anonymous" : row.UserId)</td>
                            <td class="text-truncate" style="max-width: 360px;">@row.Message</td>
                            <td class="text-end">
                                <a asp-action="ErrorLogDetail" asp-route-id="@row.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm">
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : string.Empty)">
                    <a class="page-link" asp-action="ErrorLog" asp-route-page="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                </li>
            }
        </ul>
    </nav>
}