@using Unified.Models.Identity
@using Unified.Models.Schedule
@model List<TimeOffRequest>

@{
    ViewData["Title"] = "Review Requests";
    var teams     = (IEnumerable<Team>)ViewBag.Teams;
    var selTeamId = (int)ViewBag.SelectedTeamId;
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h4 class="fw-bold mb-0"><i class="bx bx-task me-2"></i>Review Requests</h4>
        <a asp-action="WeekView" asp-route-teamId="@selTeamId" class="btn btn-outline-secondary btn-sm">← Week View</a>
    </div>

    @* Team selector *@
    <div class="card mb-3">
        <div class="card-body py-2">
            <form method="get" class="d-flex align-items-center gap-2">
                <label class="form-label mb-0 small fw-semibold">Team</label>
                <select name="teamId" class="form-select form-select-sm" style="width:200px" onchange="this.form.submit()">
                    @foreach (var t in teams)
                    {
                        <option value="@t.Id" selected="@(selTeamId == t.Id ? "selected" : null)">@t.Name</option>
                    }
                </select>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-success"><i class="bx bx-check-circle me-2"></i>No pending requests for this team.</div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Agent</th>
                            <th>Type</th>
                            <th>Dates / Times</th>
                            <th>Reason</th>
                            <th>Submitted</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@r.Agent?.DisplayName</td>
                                <td><span class="badge bg-label-primary">@r.Type</span></td>
                                <td>
                                    @r.StartDate.ToString("dd MMM yyyy")
                                    @if (r.EndDate.Date != r.StartDate.Date)
                                    {
                                        <text>– @r.EndDate.ToString("dd MMM yyyy")</text>
                                    }
                                    @if (r.Type == TimeOffType.ScheduleChange && r.RequestedStartTime.HasValue)
                                    {
                                        <br /><small class="text-muted">
                                            @r.RequestedStartTime?.ToString(@"hh\:mm") – @r.RequestedEndTime?.ToString(@"hh\:mm")
                                        </small>
                                    }
                                </td>
                                <td><small>@r.Reason</small></td>
                                <td><small>@r.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm")</small></td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-success me-1"
                                            data-bs-toggle="modal"
                                            data-bs-target="#actionModal"
                                            data-request-id="@r.Id"
                                            data-agent="@r.Agent?.DisplayName"
                                            data-action="Approve">
                                        Approve
                                    </button>
                                    <button class="btn btn-sm btn-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#actionModal"
                                            data-request-id="@r.Id"
                                            data-agent="@r.Agent?.DisplayName"
                                            data-action="Deny">
                                        Deny
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* Approve / Deny confirmation modal *@
<div class="modal fade" id="actionModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form id="actionForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="requestId" id="actionRequestId" />
                <input type="hidden" name="teamId"    value="@selTeamId" />
                <div class="modal-header">
                    <h6 class="modal-title" id="actionTitle">Confirm</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="actionBody" class="mb-2"></p>
                    <label class="form-label small">Note (optional)</label>
                    <textarea name="leaderNote" class="form-control form-control-sm" rows="2"
                              placeholder="Optional note to agent…"></textarea>
                </div>
                <div class="modal-footer py-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm" id="actionBtn">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('actionModal').addEventListener('show.bs.modal', function (e) {
    var btn    = e.relatedTarget;
    var rid    = btn.dataset.requestId;
    var agent  = btn.dataset.agent;
    var action = btn.dataset.action;
    var isApprove = action === 'Approve';

    document.getElementById('actionRequestId').value = rid;
    document.getElementById('actionTitle').textContent = action + ' Request';
    document.getElementById('actionBody').textContent  =
        action + ' request from ' + agent + '?';

    var form    = document.getElementById('actionForm');
    var baseUrl = form.getAttribute('data-base') || window.location.origin;
    form.action = '/Schedule/' + action + 'Request';

    var confirmBtn = document.getElementById('actionBtn');
    confirmBtn.className = 'btn btn-sm ' + (isApprove ? 'btn-success' : 'btn-danger');
    confirmBtn.textContent = action;
});
</script>
}
