@using Unified.Models.Schedule
@using Unified.Models.Identity
@using Unified.Models.Attendance
@model List<AgentSchedule>

@{
    ViewData["Title"] = "My Schedule";
    var weekStart     = (DateTime)ViewBag.WeekStart;
    var weekdayShifts = (IEnumerable<ShiftTemplate>)ViewBag.WeekdayShifts;
    var weekendShifts = (IEnumerable<ShiftTemplate>)ViewBag.WeekendShifts;
    var teamSchedules = (IEnumerable<AgentSchedule>)ViewBag.TeamSchedules;
    var teamMembers   = (IEnumerable<AppUser>)ViewBag.TeamMembers;
    var todayLog      = ViewBag.TodayLog as AttendanceLog;
    bool canClockIn   = todayLog == null || !todayLog.CheckInTime.HasValue;
    bool canClockOut  = todayLog != null && todayLog.CheckInTime.HasValue && !todayLog.CheckOutTime.HasValue;
    var prevWeek      = weekStart.AddDays(-7).ToString("yyyy-MM-dd");
    var nextWeek      = weekStart.AddDays(7).ToString("yyyy-MM-dd");
    var weekDays      = Enumerable.Range(0, 7).Select(i => weekStart.AddDays(i)).ToList();
    var myLookup      = Model.ToDictionary(s => s.Date.Date);
    var teamLookup    = teamSchedules.ToDictionary(s => $"{s.AgentId}_{s.Date:yyyy-MM-dd}");

    string EntryLabel(AgentSchedule? e)
    {
        if (e is null) return "";
        return e.Type switch
        {
            ScheduleEntryType.DayOff   => "Day Off",
            ScheduleEntryType.Vacation => "Vacation",
            ScheduleEntryType.Custom   => $"Reduced {e.CustomStartTime:hh\\:mm}-{e.CustomEndTime:hh\\:mm}",
            _                          => e.ShiftTemplate?.Name ?? "Working"
        };
    }

    (string text, string bg) BadgeColors(AgentSchedule? e)
    {
        if (e is null) return ("text-secondary", "bg-transparent");
        return e.Type switch
        {
            ScheduleEntryType.DayOff   => ("text-warning-emphasis", "bg-warning-subtle"),
            ScheduleEntryType.Vacation => ("text-info-emphasis",    "bg-info-subtle"),
            ScheduleEntryType.Custom   => ("text-primary-emphasis", "bg-primary-subtle"),
            _                          => ("text-success-emphasis", "bg-success-subtle")
        };
    }
}

<div class="container-xxl flex-grow-1 container-p-y">

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h4 class="fw-bold mb-0"><i class="bx bx-calendar-check me-2"></i>My Schedule</h4>
        <a asp-action="MyRequests" class="btn btn-outline-primary btn-sm">
            <i class="bx bx-time me-1"></i>My Requests
        </a>
    </div>

    @* ── Clock In / Out card ──────────────────────────────────────────────── *@
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body d-flex flex-wrap align-items-center gap-4 py-3">
            <div class="text-center" style="min-width:110px">
                <p class="text-muted small text-uppercase mb-1">Today</p>
                <div class="fw-semibold text-muted" id="sched-clock-date"></div>
            </div>
            <div class="text-center" style="min-width:90px">
                <p class="text-muted small text-uppercase mb-1">Time</p>
                <div class="fw-bold fs-5 text-muted" id="sched-live-clock"></div>
            </div>
            <div class="text-center" style="min-width:90px">
                <p class="text-muted small text-uppercase mb-1">Clocked In</p>
                <div class="fw-bold text-success">@(todayLog?.CheckInTime != null ? todayLog.CheckInTime.Value.ToLocalTime().ToString("HH:mm") : "—")</div>
            </div>
            <div class="text-center" style="min-width:90px">
                <p class="text-muted small text-uppercase mb-1">Clocked Out</p>
                <div class="fw-bold text-danger">@(todayLog?.CheckOutTime != null ? todayLog.CheckOutTime.Value.ToLocalTime().ToString("HH:mm") : "—")</div>
            </div>
            <div class="ms-auto d-flex gap-2 align-items-center flex-wrap">
                @if (TempData["Success"] != null)
                {
                    <span class="badge bg-success fs-6"><i class="bx bx-check me-1"></i>@TempData["Success"]</span>
                }
                @if (TempData["Error"] != null)
                {
                    <span class="badge bg-danger fs-6">@TempData["Error"]</span>
                }
                @if (canClockIn)
                {
                    <form asp-controller="Attendance" asp-action="ClockIn" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">
                            <i class="bx bx-log-in me-1"></i>Clock In
                        </button>
                    </form>
                }
                @if (canClockOut)
                {
                    <form asp-controller="Attendance" asp-action="ClockOut" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            <i class="bx bx-log-out me-1"></i>Clock Out
                        </button>
                    </form>
                }
                @if (!canClockIn && !canClockOut && todayLog != null)
                {
                    <span class="badge bg-success fs-6 px-3 py-2">
                        <i class="bx bx-check-circle me-1"></i>Shift complete
                    </span>
                }
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body py-2 d-flex align-items-center gap-3 flex-wrap">
            <a asp-action="AgentView" asp-route-weekStart="@prevWeek"
               class="btn btn-outline-secondary btn-sm"><i class="bx bx-chevron-left"></i></a>
            <span class="fw-semibold text-muted">
                @weekStart.ToString("dd MMM") - @weekStart.AddDays(6).ToString("dd MMM yyyy")
            </span>
            <a asp-action="AgentView" asp-route-weekStart="@nextWeek"
               class="btn btn-outline-secondary btn-sm"><i class="bx bx-chevron-right"></i></a>
            <span class="ms-auto text-muted small">Click a day below to set your shift</span>
        </div>
    </div>

    @* <%-- SECTION 1: MY ALLOCATION (editable) --%> *@
    <div class="card mb-4">
        <div class="card-header py-2 d-flex align-items-center gap-2">
            <i class="bx bx-user-check text-primary"></i>
            <span class="fw-semibold">My Allocation</span>
            <small class="text-muted ms-1">click a day to update</small>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered mb-0 text-center align-middle agent-sched-grid"
                       style="min-width:700px; table-layout:fixed">
                    <colgroup>
                        @foreach (var day in weekDays)
                        {
                            <col style="width:@(day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday ? "100px" : "130px")">
                        }
                    </colgroup>
                    <thead>
                        <tr>
                            @foreach (var day in weekDays)
                            {
                                var isWe = day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                <th class="sched-th @(isWe ? "sched-th-weekend" : "")">
                                    @day.ToString("ddd")<br />
                                    <small class="fw-normal opacity-75">@day.ToString("dd MMM")</small>
                                    @if (isWe)
                                    {
                                        <br /><small class="opacity-50" style="font-size:.65rem">Weekend</small>
                                    }
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            @foreach (var day in weekDays)
                            {
                                myLookup.TryGetValue(day.Date, out var entry);
                                var isWe   = day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                var colors = BadgeColors(entry);
                                <td class="p-2 @(isWe ? "sched-we-cell" : "")">
                                    <span class="sched-pill @colors.text @colors.bg @(entry is null ? "sched-pill-empty" : "") agent-cell"
                                          style="white-space:pre-line;cursor:pointer;min-height:48px"
                                          data-bs-toggle="modal" data-bs-target="#myDayModal"
                                          data-date="@day.ToString("yyyy-MM-dd")"
                                          data-weekend="@isWe.ToString().ToLower()"
                                          data-entry-id="@(entry?.Id ?? 0)"
                                          data-entry-type="@((int)(entry?.Type ?? ScheduleEntryType.Regular))"
                                          data-shift-id="@(entry?.ShiftTemplateId ?? 0)"
                                          data-custom-start="@(entry?.CustomStartTime?.ToString(@"hh\:mm") ?? "")"
                                          data-custom-end="@(entry?.CustomEndTime?.ToString(@"hh\:mm") ?? "")"
                                          data-note="@(entry?.Note ?? "")">
                                        @(string.IsNullOrEmpty(EntryLabel(entry)) ? "-" : EntryLabel(entry))
                                    </span>
                                    @if (entry?.Note is not null)
                                    {
                                        <div class="text-muted mt-1" style="font-size:.68rem">@entry.Note</div>
                                    }
                                </td>
                            }
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 flex-wrap mb-4">
        <span class="sched-pill text-success-emphasis bg-success-subtle px-3">Working Day</span>
        <span class="sched-pill text-primary-emphasis bg-primary-subtle px-3">Reduced Hours</span>
        <span class="sched-pill text-warning-emphasis bg-warning-subtle px-3">Day Off</span>
        <span class="sched-pill text-info-emphasis bg-info-subtle px-3">Vacation / Leave</span>
        <span class="sched-pill sched-pill-empty text-secondary bg-transparent px-3" style="border:1px dashed currentColor">Not set</span>
    </div>

    @* <%-- SECTION 2: FULL TEAM SCHEDULE (read-only) --%> *@
    <div class="card">
        <div class="card-header py-2 d-flex align-items-center gap-2">
            <i class="bx bx-group text-secondary"></i>
            <span class="fw-semibold">Team Schedule</span>
            <small class="text-muted ms-1">everyone's working hours this week</small>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered mb-0 align-middle text-center agent-sched-grid"
                       style="min-width:760px; table-layout:fixed">
                    <colgroup>
                        <col style="width:160px">
                        @foreach (var day in weekDays)
                        {
                            <col style="width:@(day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday ? "90px" : "110px")">
                        }
                    </colgroup>
                    <thead>
                        <tr>
                            <th class="sched-th text-start ps-3">Agent</th>
                            @foreach (var day in weekDays)
                            {
                                var isWe = day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                <th class="sched-th @(isWe ? "sched-th-weekend" : "")">
                                    @day.ToString("ddd")<br />
                                    <small class="fw-normal opacity-75">@day.ToString("dd MMM")</small>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in teamMembers)
                        {
                            <tr>
                                <td class="text-start ps-3 small fw-semibold">@member.DisplayName</td>
                                @foreach (var day in weekDays)
                                {
                                    teamLookup.TryGetValue($"{member.Id}_{day:yyyy-MM-dd}", out var entry);
                                    var isWe   = day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                    var colors = BadgeColors(entry);
                                    <td class="p-1 @(isWe ? "sched-we-cell" : "")">
                                        <span class="sched-pill @colors.text @colors.bg @(entry is null ? "sched-pill-empty" : "")"
                                              style="white-space:pre-line;min-height:32px;font-size:.72rem">
                                            @if (entry is not null)
                                            {
                                                if (entry.Type == ScheduleEntryType.Regular && entry.ShiftTemplate != null)
                                                {
                                                    @($"{entry.ShiftTemplate.StartTime:hh\\:mm}-{entry.ShiftTemplate.EndTime:hh\\:mm}")
                                                }
                                                else
                                                {
                                                    @EntryLabel(entry)
                                                }
                                            }
                                            else
                                            {
                                                @("-")
                                            }
                                        </span>
                                    </td>
                                }
                            </tr>
                        }
                        @if (!teamMembers.Any())
                        {
                            <tr><td colspan="8" class="text-muted py-4 text-center">No team schedule data available.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="myDayModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="SetMyDay" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="weekStart"  value="@weekStart.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="entry.Id"   id="my-entry-id" value="0" />
                <input type="hidden" name="entry.Date" id="my-date" />

                <div class="modal-header py-2">
                    <div>
                        <h6 class="modal-title mb-0">My Schedule</h6>
                        <small class="text-muted" id="my-date-display"></small>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">What are you doing this day?</label>
                        <select name="entry.Type" id="my-type" class="form-select" onchange="myToggle(this.value)">
                            <option value="0">Working Day (use shift)</option>
                            <option value="1">Reduced Day (custom hours)</option>
                            <option value="2">Day Off</option>
                            <option value="3">Vacation / Leave</option>
                        </select>
                    </div>

                    <div id="my-shiftRow" class="mb-3">
                        <label class="form-label fw-semibold">Shift</label>
                        <select name="entry.ShiftTemplateId" id="my-shift" class="form-select">
                            <option value="">-- Select --</option>
                            <optgroup label="Weekday Shifts" id="my-og-weekday">
                                @foreach (var s in weekdayShifts)
                                {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            </optgroup>
                            <optgroup label="Weekend Shifts" id="my-og-weekend">
                                @foreach (var s in weekendShifts)
                                {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            </optgroup>
                        </select>
                        <div class="form-text text-muted" id="my-shift-hint"></div>
                    </div>

                    <div id="my-customRow" class="row g-2 mb-3" style="display:none">
                        <div class="col">
                            <label class="form-label fw-semibold">Start Time</label>
                            <input type="time" name="entry.CustomStartTime" id="my-custom-start" class="form-control" step="900" />
                        </div>
                        <div class="col">
                            <label class="form-label fw-semibold">End Time</label>
                            <input type="time" name="entry.CustomEndTime" id="my-custom-end" class="form-control" step="900" />
                        </div>
                        <div class="col-12">
                            <small class="text-muted">Any start/end within your approved hours.</small>
                        </div>
                    </div>

                    <div class="mb-1">
                        <label class="form-label fw-semibold">Note <small class="fw-normal text-muted">(optional)</small></label>
                        <input type="text" name="entry.Note" id="my-note" class="form-control form-control-sm"
                               placeholder="e.g. approved by TL, dentist at 10" />
                    </div>
                </div>

                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script src="@Url.Content("~/js/schedule.js")"></script>
}
