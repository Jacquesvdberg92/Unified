@using Unified.Models.Schedule
@model List<AgentSchedule>

@{
    ViewData["Title"] = "My Schedule";
    var weekStart  = (DateTime)ViewBag.WeekStart;
    var shifts     = (IEnumerable<ShiftTemplate>)ViewBag.ShiftTemplates;
    var prevWeek   = weekStart.AddDays(-7).ToString("yyyy-MM-dd");
    var nextWeek   = weekStart.AddDays(7).ToString("yyyy-MM-dd");
    var weekDays   = Enumerable.Range(0, 7).Select(i => weekStart.AddDays(i)).ToList();
    var lookup     = Model.ToDictionary(s => s.Date.Date);

    string Label(AgentSchedule? e)
    {
        if (e is null) return "—";
        return e.Type switch
        {
            ScheduleEntryType.DayOff   => "Day Off",
            ScheduleEntryType.Vacation => "Vacation",
            ScheduleEntryType.Custom   => $"{e.CustomStartTime:hh\\:mm}–{e.CustomEndTime:hh\\:mm}",
            _                          => e.ShiftTemplate?.Name ?? "Regular"
        };
    }

    string Badge(AgentSchedule? e)
    {
        if (e is null) return "bg-label-secondary";
        return e.Type switch
        {
            ScheduleEntryType.DayOff   => "bg-label-warning",
            ScheduleEntryType.Vacation => "bg-label-info",
            ScheduleEntryType.Custom   => "bg-label-primary",
            _                          => "bg-label-success"
        };
    }
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h4 class="fw-bold mb-0"><i class="bx bx-calendar-check me-2"></i>My Schedule</h4>
        <a asp-action="MyRequests" class="btn btn-outline-primary btn-sm">
            <i class="bx bx-time me-1"></i>My Requests
        </a>
    </div>

    @* Week nav *@
    <div class="card mb-3">
        <div class="card-body py-2 d-flex align-items-center gap-3">
            <a asp-action="AgentView" asp-route-weekStart="@prevWeek"
               class="btn btn-outline-secondary btn-sm"><i class="bx bx-chevron-left"></i></a>
            <span class="fw-semibold">
                @weekStart.ToString("dd MMM") – @weekStart.AddDays(6).ToString("dd MMM yyyy")
            </span>
            <a asp-action="AgentView" asp-route-weekStart="@nextWeek"
               class="btn btn-outline-secondary btn-sm"><i class="bx bx-chevron-right"></i></a>
        </div>
    </div>

    @* Day cards *@
    <div class="row g-3">
        @foreach (var day in weekDays)
        {
            lookup.TryGetValue(day.Date, out var entry);
            var isWeekend = day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
            <div class="col-sm-6 col-md-4 col-lg-3 col-xl-@(isWeekend ? "2" : "")">
                <div class="card h-100 @(isWeekend ? "border-warning" : "")">
                    <div class="card-header py-2 d-flex justify-content-between">
                        <span class="fw-semibold">@day.ToString("ddd dd MMM")</span>
                        @if (isWeekend)
                        {
                            <span class="badge bg-label-warning">Weekend</span>
                        }
                    </div>
                    <div class="card-body py-2 text-center">
                        <span class="badge @Badge(entry) fs-6 px-3 py-2">@Label(entry)</span>
                        @if (entry?.Note is not null)
                        {
                            <p class="text-muted small mt-2 mb-0">@entry.Note</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
