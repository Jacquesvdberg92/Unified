@using Unified.Models.Identity
@using Unified.Models.Schedule
@model List<AgentSchedule>

@{
    ViewData["Title"] = "Team Schedule";
    var weekStart    = (DateTime)ViewBag.WeekStart;
    var shifts       = (IEnumerable<ShiftTemplate>)ViewBag.ShiftTemplates;
    var pendingCount = (int)ViewBag.PendingCount;
    var managerGroup = (IEnumerable<AppUser>)ViewBag.ManagerGroup;
    var teamSections = (IEnumerable<(Unified.Models.Identity.Team Team, List<AppUser> Leaders, List<AppUser> Agents)>)ViewBag.TeamSections;
    var canEdit      = (bool)ViewBag.CanEdit;
    var prevWeek     = weekStart.AddDays(-7).ToString("yyyy-MM-dd");
    var nextWeek     = weekStart.AddDays(7).ToString("yyyy-MM-dd");
    var weekDays     = Enumerable.Range(0, 7).Select(i => weekStart.AddDays(i)).ToList();
    var lookup       = Model.ToDictionary(s => $"{s.AgentId}_{s.Date:yyyy-MM-dd}");

    string EntryLabel(AgentSchedule? e)
    {
        if (e is null) return "-";
        return e.Type switch
        {
            ScheduleEntryType.DayOff   => "Day Off",
            ScheduleEntryType.Vacation => "Vacation",
            ScheduleEntryType.Custom   => $"Reduced {e.CustomStartTime:hh\\:mm}-{e.CustomEndTime:hh\\:mm}",
            _                          => e.ShiftTemplate?.Name ?? "Working"
        };
    }

    (string text, string bg) EntryColors(AgentSchedule? e)
    {
        if (e is null) return ("text-secondary", "");
        return e.Type switch
        {
            ScheduleEntryType.DayOff   => ("text-warning-emphasis", "bg-warning-subtle"),
            ScheduleEntryType.Vacation => ("text-info-emphasis",    "bg-info-subtle"),
            ScheduleEntryType.Custom   => ("text-primary-emphasis", "bg-primary-subtle"),
            _                          => ("text-success-emphasis", "bg-success-subtle")
        };
    }
}

<div class="container-xxl flex-grow-1 container-p-y">

    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h4 class="fw-bold mb-0"><i class="bx bx-calendar me-2"></i>Team Schedule</h4>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            @if (pendingCount > 0 && canEdit)
            {
                <a asp-action="ReviewRequests" class="btn btn-warning btn-sm position-relative">
                    <i class="bx bx-bell me-1"></i>Requests
                    <span class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill">@pendingCount</span>
                </a>
            }
            <a asp-action="AgentView" class="btn btn-outline-primary btn-sm">
                <i class="bx bx-user-check me-1"></i>My Schedule
            </a>
            @if (canEdit)
            {
                <a asp-action="WeekendWheel" asp-route-weekStart="@weekStart.ToString("yyyy-MM-dd")"
                   class="btn btn-outline-secondary btn-sm">
                    <i class="bx bx-rotate-right me-1"></i>Weekend Wheel
                </a>
            }
        </div>
    </div>

    @* Week navigator *@
    <div class="card mb-3">
        <div class="card-body py-2 d-flex align-items-center gap-3 flex-wrap">
            <a asp-action="WeekView" asp-route-weekStart="@prevWeek"
               class="btn btn-outline-secondary btn-sm"><i class="bx bx-chevron-left"></i></a>
            <span class="fw-semibold">
                @weekStart.ToString("dd MMM") &ndash; @weekStart.AddDays(6).ToString("dd MMM yyyy")
            </span>
            <a asp-action="WeekView" asp-route-weekStart="@nextWeek"
               class="btn btn-outline-secondary btn-sm"><i class="bx bx-chevron-right"></i></a>
            @if (!canEdit)
            {
                <small class="ms-auto text-muted"><i class="bx bx-show me-1"></i>Read-only view</small>
            }
        </div>
    </div>

    @* ?? MANAGEMENT SECTION ?????????????????????????????????????????? *@
    @if (managerGroup.Any())
    {
        <div class="card mb-4 border-0 shadow-sm">
            <div class="card-header py-2 d-flex align-items-center gap-2"
                 style="background:var(--bs-purple,#6f42c1);color:#fff">
                <i class="bx bx-crown fs-5"></i>
                <span class="fw-bold">Management</span>
                <small class="ms-auto opacity-75">@managerGroup.Count() manager@(managerGroup.Count() != 1 ? "s" : "")</small>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    @{ RenderGrid(managerGroup, "MGR"); }
                </div>
            </div>
        </div>
    }

    @* ?? PER-TEAM SECTIONS ??????????????????????????????????????????? *@
    @foreach (var sec in teamSections)
    {
        if (!sec.Leaders.Any() && !sec.Agents.Any()) { continue; }
        <div class="card mb-4 border-0 shadow-sm">
            <div class="card-header py-2 d-flex align-items-center gap-2"
                 style="border-bottom:2px solid var(--bs-primary)">
                <i class="bx bx-group text-primary fs-5"></i>
                <span class="fw-bold text-primary">@sec.Team.Name</span>
                <small class="text-muted ms-2">
                    @sec.Leaders.Count TL@(sec.Leaders.Count != 1 ? "s" : "")
                    &bull;
                    @sec.Agents.Count Agent@(sec.Agents.Count != 1 ? "s" : "")
                </small>
            </div>
            <div class="card-body p-0">
                @if (sec.Leaders.Any())
                {
                    <div class="px-3 pt-2 pb-1">
                        <small class="fw-bold text-uppercase text-primary" style="letter-spacing:.05em">
                            <i class="bx bx-star me-1"></i>Team Leaders
                        </small>
                    </div>
                    <div class="table-responsive border-bottom">
                        @{ RenderGrid(sec.Leaders, "TL"); }
                    </div>
                }
                @if (sec.Agents.Any())
                {
                    <div class="px-3 pt-2 pb-1">
                        <small class="fw-bold text-uppercase text-muted" style="letter-spacing:.05em">
                            <i class="bx bx-headphone me-1"></i>CS Agents
                        </small>
                    </div>
                    <div class="table-responsive">
                        @{ RenderGrid(sec.Agents, null); }
                    </div>
                }
            </div>
        </div>
    }

</div>

@* ?? Edit Day Modal (leaders/managers only) ??????????????????????????? *@
@if (canEdit)
{
    <div class="modal fade" id="editModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="SetAgentDay" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="weekStart"     value="@weekStart.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="entry.Id"      id="modal-entry-id" value="0" />
                    <input type="hidden" name="entry.AgentId" id="modal-agent-id" />
                    <input type="hidden" name="entry.Date"    id="modal-date" />
                    <div class="modal-header py-2">
                        <div>
                            <h6 class="modal-title mb-0" id="modal-agent-name"></h6>
                            <small class="text-muted" id="modal-date-display"></small>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Entry Type</label>
                            <select name="entry.Type" id="modal-type" class="form-select" onchange="schedToggle(this.value)">
                                <option value="0">Working Day (use shift)</option>
                                <option value="1">Reduced Day (custom hours)</option>
                                <option value="2">Day Off</option>
                                <option value="3">Vacation / Leave</option>
                            </select>
                        </div>
                        <div id="shiftRow" class="mb-3">
                            <label class="form-label fw-semibold">Shift</label>
                            <select name="entry.ShiftTemplateId" id="modal-shift" class="form-select">
                                <option value="">- Select -</option>
                                <optgroup label="Weekday Shifts" id="og-weekday">
                                    @foreach (var s in shifts.Where(s => !s.IsWeekendShift))
                                    {
                                        <option value="@s.Id">@s.Name</option>
                                    }
                                </optgroup>
                                <optgroup label="Weekend Shifts" id="og-weekend">
                                    @foreach (var s in shifts.Where(s => s.IsWeekendShift))
                                    {
                                        <option value="@s.Id">@s.Name</option>
                                    }
                                </optgroup>
                            </select>
                        </div>
                        <div id="customRow" class="row g-2 mb-3" style="display:none">
                            <div class="col">
                                <label class="form-label fw-semibold">Start</label>
                                <input type="time" name="entry.CustomStartTime" id="modal-custom-start" class="form-control" step="900" />
                            </div>
                            <div class="col">
                                <label class="form-label fw-semibold">End</label>
                                <input type="time" name="entry.CustomEndTime" id="modal-custom-end" class="form-control" step="900" />
                            </div>
                        </div>
                        <div class="mb-1">
                            <label class="form-label fw-semibold">Note <small class="fw-normal text-muted">(optional)</small></label>
                            <input type="text" name="entry.Note" id="modal-note" class="form-control form-control-sm" />
                        </div>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary btn-sm">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@* ?? Grid renderer helper ?????????????????????????????????????????????? *@
@{
    void RenderGrid(IEnumerable<AppUser> members, string? badge)
    {
        <table class="table table-bordered mb-0 align-middle text-center schedule-grid"
               style="min-width:800px;table-layout:fixed">
            <colgroup>
                <col style="width:160px">
                @foreach (var d in weekDays)
                {
                    <col style="width:@(d.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday ? "90px" : "110px")">
                }
            </colgroup>
            <thead class="table-dark">
                <tr>
                    <th class="text-start ps-3">Name</th>
                    @foreach (var d in weekDays)
                    {
                        var isWe2 = d.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                        <th class="@(isWe2 ? "text-warning" : "")">
                            @d.ToString("ddd")<br />
                            <small class="fw-normal opacity-75">@d.ToString("dd MMM")</small>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var member in members)
                {
                    <tr>
                        <td class="text-start ps-3 small fw-semibold">
                            @member.DisplayName
                            @if (badge != null)
                            {
                                <span class="badge bg-primary bg-opacity-25 text-primary ms-1" style="font-size:.6rem">@badge</span>
                            }
                        </td>
                        @foreach (var day in weekDays)
                        {
                            lookup.TryGetValue($"{member.Id}_{day:yyyy-MM-dd}", out var entry);
                            var isWe = day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                            var ec = EntryColors(entry);
                            <td class="p-1 @(isWe ? "bg-warning bg-opacity-10" : "")">
                                @if (canEdit)
                                {
                                    <span class="sched-pill @ec.text @ec.bg @(entry is null ? "sched-pill-empty" : "") sched-cell"
                                          style="white-space:pre-line;cursor:pointer"
                                          data-bs-toggle="modal" data-bs-target="#editModal"
                                          data-agent-id="@member.Id"
                                          data-agent-name="@member.DisplayName"
                                          data-date="@day.ToString("yyyy-MM-dd")"
                                          data-weekend="@isWe.ToString().ToLower()"
                                          data-entry-id="@(entry?.Id ?? 0)"
                                          data-entry-type="@((int)(entry?.Type ?? ScheduleEntryType.Regular))"
                                          data-shift-id="@(entry?.ShiftTemplateId ?? 0)"
                                          data-custom-start="@(entry?.CustomStartTime?.ToString(@"hh\:mm") ?? "")"
                                          data-custom-end="@(entry?.CustomEndTime?.ToString(@"hh\:mm") ?? "")"
                                          data-note="@(entry?.Note ?? "")">@EntryLabel(entry)</span>
                                }
                                else
                                {
                                    <span class="sched-pill @ec.text @ec.bg @(entry is null ? "sched-pill-empty" : "")"
                                          style="white-space:pre-line">@EntryLabel(entry)</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
}


@section Scripts {
@if (canEdit)
{
<script src="@Url.Content("~/js/schedule.js")"></script>
}
}

