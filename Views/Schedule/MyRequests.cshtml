@using Unified.Models.Schedule
@model List<TimeOffRequest>

@{
    ViewData["Title"] = "My Requests";
    var newlyActioned = (int)(ViewBag.NewlyActioned ?? 0);
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h4 class="fw-bold mb-0"><i class="bx bx-calendar-event me-2"></i>My Requests</h4>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#submitModal">
            <i class="bx bx-plus me-1"></i>New Request
        </button>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">You have no requests yet.</div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Type</th>
                            <th>Dates</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>Leader Note</th>
                            <th>Submitted</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            var badge = r.Status switch
                            {
                                TimeOffStatus.Pending  => "bg-label-warning",
                                TimeOffStatus.Approved => "bg-label-success",
                                TimeOffStatus.Denied   => "bg-label-danger",
                                _                      => "bg-label-secondary"
                            };
                            <tr>
                                <td><span class="badge bg-label-primary">@r.Type</span></td>
                                <td>
                                    @r.StartDate.ToString("dd MMM yyyy")
                                    @if (r.EndDate.Date != r.StartDate.Date)
                                    {
                                        <text>– @r.EndDate.ToString("dd MMM yyyy")</text>
                                    }
                                    @if (r.Type == TimeOffType.ScheduleChange && r.RequestedStartTime.HasValue)
                                    {
                                        <br /><small class="text-muted">@r.RequestedStartTime:hh\:mm – @r.RequestedEndTime:hh\:mm</small>
                                    }
                                </td>
                                <td>@r.Reason</td>
                                <td><span class="badge @badge">@r.Status</span></td>
                                <td><small class="text-muted">@r.LeaderNote</small></td>
                                <td><small>@r.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm")</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* Submit Request Modal *@
<div class="modal fade" id="submitModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="SubmitRequest" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">New Request</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Request Type</label>
                        <select name="request.Type" id="reqType" class="form-select" onchange="toggleScheduleFields()">
                            <option value="0">Vacation</option>
                            <option value="1">Day Off</option>
                            <option value="2">Schedule Change</option>
                        </select>
                    </div>
                    <div class="mb-3" id="dateRangeRow">
                        <label class="form-label">Date Range</label>
                        <div class="row g-2">
                            <div class="col">
                                <input type="date" name="request.StartDate" class="form-control" required id="startDate" />
                            </div>
                            <div class="col" id="endDateCol">
                                <input type="date" name="request.EndDate" class="form-control" required id="endDate" />
                            </div>
                        </div>
                    </div>
                    <div id="scheduleTimeRow" style="display:none">
                        <div class="row g-2 mb-3">
                            <div class="col">
                                <label class="form-label">Requested Start</label>
                                <input type="time" name="request.RequestedStartTime" class="form-control" id="reqStart" />
                            </div>
                            <div class="col">
                                <label class="form-label">Requested End</label>
                                <input type="time" name="request.RequestedEndTime" class="form-control" id="reqEnd" />
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reason</label>
                        <textarea name="request.Reason" class="form-control" rows="3" placeholder="Brief explanation…" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function toggleScheduleFields() {
    var type = document.getElementById('reqType').value;
    var isScheduleChange = type === '2';
    document.getElementById('scheduleTimeRow').style.display = isScheduleChange ? '' : 'none';
    // For Day Off/ScheduleChange sync end=start on start change
    if (type === '1' || type === '2') {
        document.getElementById('endDateCol').style.display = 'none';
        document.getElementById('startDate').addEventListener('change', function () {
            document.getElementById('endDate').value = this.value;
        });
    } else {
        document.getElementById('endDateCol').style.display = '';
    }
}
toggleScheduleFields();

@if (newlyActioned > 0)
{
    <text>
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof Toastify === 'function') {
            Toastify({
                text: "@newlyActioned of your request(s) have been reviewed.",
                duration: 5000,
                close: true,
                gravity: "top",
                position: "right",
                style: { background: "linear-gradient(to right, #405189, #0ab39c)" }
            }).showToast();
        }
    });
    </text>
}
</script>
}
