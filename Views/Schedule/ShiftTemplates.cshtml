@using Unified.Models.Identity
@using Unified.Models.Schedule
@model List<ShiftTemplate>

@{
    ViewData["Title"] = "Manage Shift Templates";
    var isBrandManager = User.IsInRole(Roles.BrandManager);
}

<div class="container-xxl flex-grow-1 container-p-y">

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h4 class="fw-bold mb-0"><i class="bx bx-time-five me-2"></i>Shift Templates</h4>
        <div class="d-flex gap-2">
            <a asp-action="WeekView" class="btn btn-outline-secondary btn-sm">
                <i class="bx bx-arrow-back me-1"></i>Back to Schedule
            </a>
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addShiftModal">
                <i class="bx bx-plus me-1"></i>Add Shift
            </button>
        </div>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bx bx-check-circle me-1"></i>@success
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bx bx-error me-1"></i>@error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Weekend</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No shift templates found. Add one above.</td>
                        </tr>
                    }
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@t.Name</td>
                            <td>@t.StartTime.ToString(@"hh\:mm")</td>
                            <td>@t.EndTime.ToString(@"hh\:mm")</td>
                            <td>
                                @if (t.IsWeekendShift)
                                {
                                    <span class="badge bg-label-info"><i class="bx bx-check me-1"></i>Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-secondary">No</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editShiftModal"
                                        data-id="@t.Id"
                                        data-name="@t.Name"
                                        data-start="@t.StartTime.ToString(@"hh\:mm")"
                                        data-end="@t.EndTime.ToString(@"hh\:mm")"
                                        data-weekend="@t.IsWeekendShift.ToString().ToLower()">
                                    <i class="bx bx-edit-alt"></i>
                                </button>
                                @if (isBrandManager)
                                {
                                    <form asp-action="DeleteShiftTemplate" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete shift \'@t.Name\'? This cannot be undone.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@t.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger ms-1">
                                            <i class="bx bx-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Add Modal *@
<div class="modal fade" id="addShiftModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="CreateShiftTemplate" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bx bx-plus me-1"></i>Add Shift Template</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="e.g. Morning" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col">
                            <label class="form-label">Start Time</label>
                            <input type="time" name="StartTime" class="form-control" required />
                        </div>
                        <div class="col">
                            <label class="form-label">End Time</label>
                            <input type="time" name="EndTime" class="form-control" required />
                        </div>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="IsWeekendShift" value="true" id="addWeekend" />
                        <label class="form-check-label" for="addWeekend">Weekend Shift</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bx bx-save me-1"></i>Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Edit Modal *@
<div class="modal fade" id="editShiftModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="EditShiftTemplate" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bx bx-edit me-1"></i>Edit Shift Template</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" name="Name" id="editName" class="form-control" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col">
                            <label class="form-label">Start Time</label>
                            <input type="time" name="StartTime" id="editStart" class="form-control" required />
                        </div>
                        <div class="col">
                            <label class="form-label">End Time</label>
                            <input type="time" name="EndTime" id="editEnd" class="form-control" required />
                        </div>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="IsWeekendShift" value="true" id="editWeekend" />
                        <label class="form-check-label" for="editWeekend">Weekend Shift</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bx bx-save me-1"></i>Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('editShiftModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('editId').value      = btn.dataset.id;
            document.getElementById('editName').value    = btn.dataset.name;
            document.getElementById('editStart').value   = btn.dataset.start;
            document.getElementById('editEnd').value     = btn.dataset.end;
            document.getElementById('editWeekend').checked = btn.dataset.weekend === 'true';
        });
    </script>
}
