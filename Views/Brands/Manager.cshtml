@model IEnumerable<Unified.Models.EmailTemplates.Brand>
@using Unified.Models.EmailTemplates
@{
    ViewData["Title"] = "Brand Manager";
    var docMap = ViewBag.DocumentMap as Dictionary<int, List<BrandDocument>> ?? new();
}

<div class="d-md-flex d-block align-items-center justify-content-between my-4 page-header-breadcrumb">
    <h1 class="page-title fw-semibold fs-18 mb-0">Brand Manager</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="ri-add-line me-1"></i> New Brand
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@foreach (var brand in Model)
{
    var brandDocs = docMap.TryGetValue(brand.Id, out var d) ? d : new List<BrandDocument>();

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@brand.Name</h5>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@brand.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <form asp-action="Delete" asp-route-id="@brand.Id" method="post" class="d-inline"
                      onsubmit="return confirm('Delete brand @brand.Name?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3 text-muted"><strong>CRM:</strong> @(brand.CrmUrl ?? "—")</div>
                <div class="col-md-3 text-muted"><strong>Quemetrics:</strong> @(brand.QuemetricsUrl ?? "—")</div>
                <div class="col-md-6 text-muted">
                    <strong>Brand Links:</strong>
                    @{
                        var links = brand.GetBrandLinks();
                    }
                    @if (links.Any())
                    {
                        <ul class="mb-0 ps-3">
                            @foreach (var l in links)
                            {
                                <li>@l.Label — <a href="@l.Url" target="_blank">@l.Url</a></li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span class="text-muted">None configured</span>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(brand.FooterSignatureHtml) || !string.IsNullOrWhiteSpace(brand.ZohoSignatureNote))
            {
                <hr />
                <h6>ZoHo Signature</h6>
                @if (!string.IsNullOrWhiteSpace(brand.ZohoSignatureNote))
                {
                    <p class="text-muted small">@brand.ZohoSignatureNote</p>
                }
                @if (!string.IsNullOrWhiteSpace(brand.FooterSignatureHtml))
                {
                    <div class="border rounded p-2 bg-light mb-2" id="sig-preview-@brand.Id">
                        @Html.Raw(brand.FooterSignatureHtml)
                    </div>
                    <button class="btn btn-sm btn-outline-secondary copy-sig-btn"
                            data-brand-id="@brand.Id"
                            data-sig="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(brand.FooterSignatureHtml))">
                        <i class="ri-clipboard-line me-1"></i> Copy Signature HTML
                    </button>
                }
            }

            @if (brandDocs.Any())
            {
                <hr />
                <h6><i class="bx bx-file me-1"></i> Documents</h6>
                <ul class="list-group list-group-flush">
                    @foreach (var doc in brandDocs)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <a asp-action="Download" asp-route-docId="@doc.Id" target="_blank">
                                <i class="bx bx-file-blank me-1 text-primary"></i>@doc.OriginalName
                            </a>
                            <div class="d-flex align-items-center gap-2">
                                <small class="text-muted">@doc.UploadedAt.ToString("yyyy-MM-dd")</small>
                                <form asp-action="DeleteDocument" method="post" class="d-inline"
                                      onsubmit="return confirm('Remove document \'@doc.OriginalName\'?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="docId" value="@doc.Id" />
                                    <input type="hidden" name="brandId" value="@brand.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger py-0">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
}

@section Scripts {
    <script src="@Url.Content("~/js/email-templates.js")"></script>
}
