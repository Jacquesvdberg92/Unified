@using Unified.Models.Vault
@model VaultEntrySummary

@{
    var fieldId      = $"pwd_{Model.Id}";
    var userFieldId  = $"usr_{Model.Id}";
}

<div class="card shadow-sm h-100 vault-card">
    <div class="card-header d-flex align-items-center justify-content-between py-2">
        <span>
            <i class="@(Model.CategoryIconCssClass ?? "bx bx-lock") me-1"></i>
            <span class="fw-semibold">@Model.Label</span>
        </span>
        <div class="d-flex gap-1">
            <a asp-controller="Vault" asp-action="EditEntry" asp-route-id="@Model.Id"
               class="btn btn-outline-secondary btn-sm py-0">✏</a>
            <form asp-controller="Vault" asp-action="DeleteEntry" asp-route-id="@Model.Id"
                  method="post" class="d-inline"
                  onsubmit="return confirm('Delete this entry?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm py-0">🗑</button>
            </form>
        </div>
    </div>
    <div class="card-body p-3">
        @* Username row *@
        <div class="mb-2">
            <label class="form-label small text-muted mb-0">Username</label>
            <div class="input-group input-group-sm">
                <input id="@userFieldId" type="text" readonly value="@Model.Username"
                       class="form-control form-control-sm bg-light" />
                <button type="button" class="btn btn-outline-secondary btn-copy"
                        data-entry-id="@Model.Id" data-type="username" data-field-id="@userFieldId"
                        title="Copy username">
                    📋
                </button>
            </div>
        </div>

        @* Password row *@
        <div class="mb-2">
            <label class="form-label small text-muted mb-0">Password</label>
            <div class="input-group input-group-sm">
                <input id="@fieldId" type="password" readonly value=""
                       class="form-control form-control-sm bg-light" />
                <button type="button" class="btn btn-outline-secondary btn-reveal"
                        data-entry-id="@Model.Id" data-field-id="@fieldId" data-action="View"
                        title="Reveal password">👁</button>
                <button type="button" class="btn btn-outline-secondary btn-copy"
                        data-entry-id="@Model.Id" data-type="password" data-field-id="@fieldId"
                        title="Copy password">📋</button>
            </div>
        </div>

        @* URL *@
        @if (!string.IsNullOrWhiteSpace(Model.Url))
        {
            <a href="@Model.Url" target="_blank" rel="noopener noreferrer"
               class="btn btn-outline-primary btn-sm w-100">🔗 Open Login Page</a>
        }

        @* Notes *@
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <p class="text-muted small mt-2 mb-0">@Model.Notes</p>
        }
    </div>
</div>
