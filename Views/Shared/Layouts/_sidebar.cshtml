            <aside class="app-sidebar sticky" id="sidebar">

                <!-- Start::main-sidebar-header -->
                <div class="main-sidebar-header">
                    <a asp-controller="Home" asp-action="index" class="header-logo">
                        <span class="fw-bold fs-5 text-white">Unified</span>
                    </a>
                </div>
                <!-- End::main-sidebar-header -->

                <!-- Start::main-sidebar -->
                <div class="main-sidebar" id="sidebar-scroll">

                    <!-- Start::nav -->
                    <nav class="main-menu-container nav nav-pills flex-column sub-open">
                        <ul class="main-menu">
                            <li class="slide__category"><span class="category-name">Main</span></li>

                            <li class="slide">
                                <a asp-controller="Home" asp-action="index" class="side-menu__item">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 side-menu__icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
                                    <span class="side-menu__label">Dashboard</span>
                                </a>
                            </li>

                            <li class="slide">
                                <a asp-controller="Updates" asp-action="Feed" class="side-menu__item">
                                    <i class="bx bx-news side-menu__icon"></i>
                                    <span class="side-menu__label">Updates Feed</span>
                                </a>
                            </li>

                            <li class="slide">
                                <a asp-controller="ProcessTemplates" asp-action="Index" class="side-menu__item">
                                    <i class="bx bx-file side-menu__icon"></i>
                                    <span class="side-menu__label">Process Templates</span>
                                </a>
                            </li>

                            <li class="slide">
                                <a asp-controller="Schedule" asp-action="AgentView" class="side-menu__item">
                                    <i class="bx bx-calendar-check side-menu__icon"></i>
                                    <span class="side-menu__label">My Schedule</span>
                                </a>
                            </li>

                            <li class="slide">
                                <a asp-controller="Schedule" asp-action="MyRequests" class="side-menu__item">
                                    <i class="bx bx-calendar-event side-menu__icon"></i>
                                    <span class="side-menu__label">My Requests</span>
                                </a>
                            </li>

                            @if (User.IsInRole("BrandManager") || User.IsInRole("TeamLeader"))
                            {
                                <li class="slide__category"><span class="category-name">Management</span></li>

                                <li class="slide">
                                    <a asp-controller="Schedule" asp-action="WeekView" class="side-menu__item">
                                        <i class="bx bx-calendar side-menu__icon"></i>
                                        <span class="side-menu__label">Team Schedule</span>
                                    </a>
                                </li>

                                <li class="slide">
                                    <a asp-controller="Schedule" asp-action="ReviewRequests" class="side-menu__item">
                                        <i class="bx bx-task side-menu__icon"></i>
                                        <span class="side-menu__label">Review Requests</span>
                                    </a>
                                </li>

                                <li class="slide">
                                    <a asp-controller="EmailTemplates" asp-action="Index" class="side-menu__item">
                                        <i class="bx bx-envelope side-menu__icon"></i>
                                        <span class="side-menu__label">Email Templates</span>
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("BrandManager"))
                            {
                                <li class="slide__category"><span class="category-name">Admin</span></li>
                                <li class="slide">
                                    <a asp-controller="Admin" asp-action="Index" class="side-menu__item">
                                        <i class="bx bx-shield side-menu__icon"></i>
                                        <span class="side-menu__label">Admin</span>
                                    </a>
                                </li>
                            }

                        </ul>
                    </nav>
                    <!-- End::nav -->

                </div>
                <!-- End::main-sidebar -->

            </aside>
