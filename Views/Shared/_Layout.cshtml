@inject Microsoft.Extensions.Configuration.IConfiguration _cfg
<!DOCTYPE html>
<html lang="en" dir="ltr" data-nav-layout="vertical" data-theme-mode="light" data-header-styles="light" data-menu-styles="dark" data-toggled="close">

    <head>

        <!-- META DATA -->
		<meta charset="UTF-8">
        <meta name='viewport' content='width=device-width, initial-scale=1.0'>
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="Description" content="Unified — Internal operations tool">

		<!-- TITLE -->
		<title>@ViewData["Title"] — Unified</title>

		<!-- FAVICON -->
        <link rel="icon" type="image/png" href="@Url.Content("~/fav.png")">

        <!-- BOOTSTRAP CSS -->
	    <link  id="style" href="@Url.Content("~/assets/libs/bootstrap/css/bootstrap.min.css")" rel="stylesheet">

        <!-- STYLES CSS -->
        <link href="@Url.Content("~/assets/css/styles.css")" rel="stylesheet">

        <!-- ICONS CSS -->
        <link href="@Url.Content("~/assets/CSS/icons.css")" rel="stylesheet">
        
        <partial name="~/Views/Shared/Layouts/_styles.cshtml">

        <!-- SITE CSS -->
        <link rel="stylesheet" href="@Url.Content("~/css/site.css")">

        @if (_cfg["Demo:Enabled"] == "true")
        {
            <style>
                :root { --demo-banner-h: 2rem; }
                .demo-preview-banner {
                    position: fixed;
                    top: 0;
                    left: 0;
                    right: 0;
                    z-index: 99999;
                    height: var(--demo-banner-h);
                    background: linear-gradient(90deg, #6366f1 0%, #8b5cf6 100%);
                    color: #fff;
                    text-align: center;
                    font-size: 0.8125rem;
                    font-weight: 600;
                    letter-spacing: 0.03em;
                    line-height: var(--demo-banner-h);
                    padding: 0 1rem;
                    box-shadow: 0 2px 8px rgba(99,102,241,.35);
                    pointer-events: none;
                    user-select: none;
                }
                body { padding-top: var(--demo-banner-h); }
                #header { top: var(--demo-banner-h) !important; }
            </style>
        }

        <!-- MAIN JS -->
        <script src="@Url.Content("~/assets/js/main.js")" defer></script>

		@await RenderSectionAsync("Styles", required: false)

		<!-- TOASTIFY CSS -->
		<link rel="stylesheet" href="@Url.Content("~/assets/libs/toastify-js/src/toastify.css")">

	</head>

	<body>

        @if (_cfg["Demo:Enabled"] == "true")
        {
            <div class="demo-preview-banner" role="banner" aria-label="Demo preview banner">
                🔍 Preview Mode — You are viewing a live demo. Data may be reset periodically.
            </div>
        }

        <!-- SWITCHER -->
        <partial name="~/Views/Shared/Layouts/_switcher.cshtml">
        <!-- END SWITCHER -->

        <!-- LOADER -->
		<div id="loader">
            <div class="spinner-border text-primary" role="status" aria-label="Loading"></div>
		</div>
		<!-- END LOADER -->

        <!-- PAGE -->
		<div class="page">

            <!-- HEADER -->
            <partial name="~/Views/Shared/Layouts/_header.cshtml">

            <!-- END HEADER -->

            <!-- SIDEBAR -->

            <partial name="~/Views/Shared/Layouts/_sidebar.cshtml">

            <!-- END SIDEBAR -->

            <!-- MAIN-CONTENT -->

            <div class="main-content app-content">
                <div class="container-fluid">
                    <partial name="~/Views/Shared/_Breadcrumbs.cshtml" />
                    @RenderBody()
                </div>
            </div>
            <!-- END MAIN-CONTENT -->

            <!-- FOOTER -->
            <partial name="~/Views/Shared/Layouts/_footer.cshtml">

            <!-- END FOOTER -->

		</div>
        <!-- END PAGE-->

        <!-- SCRIPTS -->

        <partial name="~/Views/Shared/Layouts/_scripts.cshtml">

        <!-- TOASTIFY JS -->
        <script src="@Url.Content("~/assets/libs/toastify-js/src/toastify.js")" defer></script>

        @await RenderSectionAsync("Scripts", required: false)

        <partial name="~/Views/Shared/_Toast.cshtml" />

        <partial name="~/Views/Shared/_PinnedUpdatesToast.cshtml" />

		<!-- STICKY JS -->
		<script src="@Url.Content("~/assets/js/sticky.js")" defer></script>

		<!-- DASHBOARD WIDGETS JS -->
		<script src="@Url.Content("~/js/dashboard-widgets.js")" defer></script>

		<!-- CUSTOM JS -->
		<script src="@Url.Content("~/assets/js/custom.js")" defer></script>

		<!-- CUSTOM-SWITCHER JS -->
		<script src="@Url.Content("~/assets/js/custom-switcher.js")" defer></script>

        <!-- END SCRIPTS -->

	</body>
</html>
