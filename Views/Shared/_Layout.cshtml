<!DOCTYPE html>
<html lang="en" dir="ltr" data-nav-layout="vertical" data-theme-mode="light" data-header-styles="light" data-menu-styles="dark" data-toggled="close">

    <head>

        <!-- META DATA -->
		<meta charset="UTF-8">
        <meta name='viewport' content='width=device-width, initial-scale=1.0'>
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="Description" content="Unified — Internal operations tool">

		<!-- TITLE -->
		<title>@ViewData["Title"] — Unified</title>

		<!-- FAVICON -->
		<link rel="icon" type="image/x-icon" href="@Url.Content("~/favicon.ico")">

        <!-- BOOTSTRAP CSS -->
	    <link  id="style" href="@Url.Content("~/assets/libs/bootstrap/css/bootstrap.min.css")" rel="stylesheet">

        <!-- STYLES CSS -->
        <link href="@Url.Content("~/assets/css/styles.css")" rel="stylesheet">

        <!-- ICONS CSS -->
        <link href="@Url.Content("~/assets/CSS/icons.css")" rel="stylesheet">
        
        <partial name="~/Views/Shared/Layouts/_styles.cshtml">

        <!-- MAIN JS -->
        <script src="@Url.Content("~/assets/js/main.js")"></script>

		@await RenderSectionAsync("Styles", required: false)

		<!-- TOASTIFY CSS -->
		<link rel="stylesheet" href="@Url.Content("~/assets/libs/toastify-js/src/toastify.css")">

	</head>

	<body>

        <!-- SWITCHER -->
        <partial name="~/Views/Shared/Layouts/_switcher.cshtml">
        <!-- END SWITCHER -->

        <!-- LOADER -->
		<div id="loader">
			<img src="@Url.Content("~/assets/images/media/loader.svg")" alt="">
		</div>
		<!-- END LOADER -->

        <!-- PAGE -->
		<div class="page">

            <!-- HEADER -->
            <partial name="~/Views/Shared/Layouts/_header.cshtml">

            <!-- END HEADER -->

            <!-- SIDEBAR -->

            <partial name="~/Views/Shared/Layouts/_sidebar.cshtml">

            <!-- END SIDEBAR -->

            <!-- MAIN-CONTENT -->

            <div class="main-content app-content">
                <div class="container-fluid">
                    <partial name="~/Views/Shared/_Breadcrumbs.cshtml" />
                    @RenderBody()
                </div>
            </div>
            <!-- END MAIN-CONTENT -->

            <!-- FOOTER -->
            <partial name="~/Views/Shared/Layouts/_footer.cshtml">

            <!-- END FOOTER -->

		</div>
        <!-- END PAGE-->

        <!-- SCRIPTS -->

        <partial name="~/Views/Shared/Layouts/_scripts.cshtml">

        <!-- TOASTIFY JS -->
        <script src="@Url.Content("~/assets/libs/toastify-js/src/toastify.js")"></script>

        @await RenderSectionAsync("Scripts", required: false)

        <partial name="~/Views/Shared/_Toast.cshtml" />

        <partial name="~/Views/Shared/_PinnedUpdatesToast.cshtml" />

		<!-- STICKY JS -->
		<script src="@Url.Content("~/assets/js/sticky.js")"></script>

		<!-- DASHBOARD WIDGETS JS -->
		<script src="@Url.Content("~/js/dashboard-widgets.js")"></script>

		<!-- CUSTOM JS -->
		<script src="@Url.Content("~/assets/js/custom.js")"></script>

        <!-- CUSTOM-SWITCHER JS -->
        <script src="@Url.Content("~/assets/js/custom-switcher.js")"></script>

        <!-- END SCRIPTS -->

	</body>
</html>
