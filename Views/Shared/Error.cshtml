@model ErrorViewModel
@{
    var statusCode = Context.Request.Query["statusCode"].FirstOrDefault();
    var is404 = statusCode == "404";
    ViewData["Title"] = is404 ? "Page Not Found" : "Error";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-6 text-center">
        @if (is404)
        {
            <h1 class="display-1 fw-bold text-primary">404</h1>
            <h2 class="mb-3">Page Not Found</h2>
            <p class="text-muted mb-4">The page you are looking for doesn&rsquo;t exist or has been moved.</p>
        }
        else
        {
            <h1 class="display-1 fw-bold text-danger">500</h1>
            <h2 class="mb-3">Something Went Wrong</h2>
            <p class="text-muted mb-4">An unexpected error occurred. Please try again later.</p>
            @if (Model?.ShowRequestId == true)
            {
                <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
            }
        }
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-wave">
            <i class="bx bx-home me-1"></i> Back to Dashboard
        </a>
    </div>
</div>
