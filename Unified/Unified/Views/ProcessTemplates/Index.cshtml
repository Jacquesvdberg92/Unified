@using Unified.Models.Identity
@model List<Unified.Models.ProcessTemplates.ProcessTemplate>

@{
    ViewData["Title"] = "Process Template Library";
    var categories = (IEnumerable<Unified.Models.ProcessTemplates.TemplateCategory>)ViewBag.Categories;
    var brands     = (IEnumerable<Unified.Models.EmailTemplates.Brand>)ViewBag.Brands;
    var selCat     = (int?)ViewBag.SelectedCategory;
    var selBrand   = (int?)ViewBag.SelectedBrandId;
    var search     = (string?)ViewBag.Search;
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Process Template Library</h4>
        @if (User.IsInRole(Roles.BrandManager) || User.IsInRole(Roles.TeamLeader))
        {
            <a asp-action="Create" class="btn btn-primary"><i class="bx bx-plus me-1"></i>New Template</a>
        }
    </div>

    <div class="row g-4">
        {{!-- Sidebar --}}
        <div class="col-lg-3">
            <form method="get" id="filterForm">
                <div class="card mb-3">
                    <div class="card-body">
                        <h6 class="mb-3">Filter</h6>
                        <div class="mb-3">
                            <label class="form-label small">Search</label>
                            <input name="search" class="form-control form-control-sm" value="@search" placeholder="Keyword…" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Category</label>
                            <select name="categoryId" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">All Categories</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id" @(selCat == cat.Id ? "selected" : "")>@cat.Name</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Brand</label>
                            <select name="brandId" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">All Brands</option>
                                @foreach (var brand in brands)
                                {
                                    <option value="@brand.Id" @(selBrand == brand.Id ? "selected" : "")>@brand.Name</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-outline-secondary btn-sm w-100">Apply</button>
                        @if (selCat.HasValue || selBrand.HasValue || !string.IsNullOrWhiteSpace(search))
                        {
                            <a asp-action="Index" class="btn btn-link btn-sm w-100 text-center mt-1">Clear Filters</a>
                        }
                    </div>
                </div>

                <div class="card">
                    <div class="list-group list-group-flush">
                        <a asp-action="Index" class="list-group-item list-group-item-action @(selCat == null ? "active" : "")">
                            <i class="bx bx-category me-2"></i>All Categories
                        </a>
                        @foreach (var cat in categories)
                        {
                            <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-brandId="@selBrand" asp-route-search="@search"
                               class="list-group-item list-group-item-action @(selCat == cat.Id ? "active" : "")">
                                @if (cat.IconCssClass is not null) { <i class="@cat.IconCssClass me-2"></i> }
                                @cat.Name
                            </a>
                        }
                    </div>
                </div>
            </form>
        </div>

        {{!-- Cards grid --}}
        <div class="col-lg-9">
            @if (!Model.Any())
            {
                <div class="alert alert-info">No templates found matching your filters.</div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var template in Model)
                    {
                        <div class="col-md-6 col-xl-4">
                            @await Html.PartialAsync("_TemplateCard", template)
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
