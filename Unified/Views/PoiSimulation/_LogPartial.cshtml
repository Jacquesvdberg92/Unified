@using Unified.Models.EmailTemplates
@{
    var brands = (List<Brand>)ViewBag.Brands;
}

<form asp-controller="PoiSimulation" asp-action="Log" method="post"
      data-ajax-form data-widget-key="poi_simulations poi_report" data-close-modal="poiLogModal">
    @Html.AntiForgeryToken()

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger mb-3">
            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@err.ErrorMessage</div>
            }
        </div>
    }

    <div class="mb-3">
        <label class="form-label fw-semibold">Client ID <span class="text-danger">*</span></label>
        <input type="text" name="clientId" class="form-control"
               placeholder="e.g. 123456" required autofocus />
        <div class="form-text">Enter the account/client ID that was simulated.</div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Brand <span class="text-danger">*</span></label>
        <select name="brandId" class="form-select" required>
            <option value="">— Select brand —</option>
            @foreach (var b in brands)
            {
                <option value="@b.Id">@b.Name</option>
            }
        </select>
    </div>

    <div class="mb-4">
        <label class="form-label fw-semibold">Notes</label>
        <textarea name="notes" class="form-control" rows="3"
                  placeholder="Optional: reason for simulation, ticket reference, etc."></textarea>
    </div>

    <div class="alert alert-warning small mb-4">
        <i class="bx bx-info-circle me-1"></i>
        <strong>Reminder:</strong> Trade will be restricted after <strong>3 days</strong>
        unless a valid ID copy is received and marked in the system.
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">
            <i class="bx bx-save me-1"></i> Log Simulation
        </button>
    </div>
</form>
